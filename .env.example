SESSION_SECRET=una-cadena-larga-random-aqui
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Supabase Storage (opcional) ──
# Si se configuran, las fotos de remitos se guardan en Supabase Storage
# (persisten entre reinicios). Si se dejan vacías, se usan archivos locales.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-clave-service-role-secreta
SUPABASE_BUCKET=remitos
