<%
  // Params: opId, recursos, choferes, camiones, editable, solapamiento (optional)
  const r = recursos || {}
%>
<div class="card shadow-sm">
  <div class="card-header card-header-light d-flex justify-content-between align-items-center">
    <span><%- icon('truck', { size: 15 }) %> Recursos asignados</span>
  </div>
  <div class="card-body">
    <div class="row g-3 mb-2">
      <div class="col-md-6">
        <small class="text-muted d-block">Camión</small>
        <p class="fw-semibold mb-0"><%= r.camion_label && r.camion_label.trim() ? r.camion_label : '— sin asignar —' %></p>
      </div>
      <div class="col-md-6">
        <small class="text-muted d-block">Chofer</small>
        <p class="fw-semibold mb-0"><%= r.chofer_nombre && r.chofer_nombre.trim() ? r.chofer_nombre : '— sin asignar —' %></p>
      </div>
    </div>
    <% if (r.asignacion_fecha) { %>
      <p class="text-muted small mb-0">Asignado el <%= formatFechaHora(r.asignacion_fecha) %><%= r.asignado_por ? ' por ' + r.asignado_por : '' %></p>
    <% } %>

    <% if (typeof solapamiento !== 'undefined' && solapamiento && solapamiento.opId === String(opId)) { %>
      <hr class="my-3">
      <div class="alert alert-warning p-3 rounded-3" style="border-left:4px solid #f59e0b">
        <p class="fw-semibold mb-2">⚠️ Solapamiento de horario detectado</p>
        <% solapamiento.advertencias.forEach(a => { %><p class="small mb-1"><%= a %></p><% }) %>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="this.closest('.alert').remove()">Entiendo, continuar así</button>
          <form action="/operaciones/<%= opId %>/retrasar30" method="POST" class="d-inline">
            <button class="btn btn-sm btn-warning">⏱ Atrasar 30 minutos</button>
          </form>
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="this.closest('.alert').remove(); document.getElementById('selChofer-<%= opId %>')?.focus()">Elegir otro chofer / camión</button>
        </div>
      </div>
    <% } %>
    <% if (editable) { %>
      <hr class="my-3">
      <form action="/operaciones/<%= opId %>/recursos" method="POST" id="formRecursosOp-<%= opId %>">
        <div class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label">Camión</label>
            <select name="id_camion" class="form-select form-select-sm" id="selCamion-<%= opId %>">
              <option value="">— sin asignar —</option>
              <% camiones.forEach(v => { %>
                <option value="<%= v.id %>" data-chofer="<%= v.chofer_id || '' %>" <%= r.id_camion===v.id?'selected':'' %>>
                  <%= [v.patente, v.nombre, [v.marca,v.modelo].filter(Boolean).join(' ')].filter(Boolean).join(' · ') %> — <%= v.ocupado ? '🔴 Ocupado' : '🟢 Disponible' %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-5">
            <label class="form-label">Chofer</label>
            <select name="id_chofer" class="form-select form-select-sm" id="selChofer-<%= opId %>">
              <option value="">— sin asignar —</option>
              <% choferes.forEach(c => { %>
                <option value="<%= c.id %>" data-camion="<%= c.camion_id || '' %>" <%= r.id_chofer===c.id?'selected':'' %>><%= c.nombre %> <%= c.apellido %> — <%= c.ocupado ? '🔴 Ocupado' : '🟢 Disponible' %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-auto"><button class="btn btn-sm btn-naranja">Guardar</button></div>
        </div>
        <p class="form-text mb-0 mt-1">Al elegir un chofer o un camión, se autocompleta el otro si ya están asignados entre sí.</p>
      </form>
      <script>
        (function () {
          var selChofer = document.getElementById('selChofer-<%= opId %>')
          var selCamion = document.getElementById('selCamion-<%= opId %>')
          if (!selChofer || !selCamion) return
          var syncing = false
          selChofer.addEventListener('change', function () {
            if (syncing) return
            var opt = selChofer.options[selChofer.selectedIndex]
            var camionId = opt && opt.getAttribute('data-camion')
            if (camionId) { syncing = true; selCamion.value = String(camionId); syncing = false }
          })
          selCamion.addEventListener('change', function () {
            if (syncing) return
            var opt = selCamion.options[selCamion.selectedIndex]
            var choferId = opt && opt.getAttribute('data-chofer')
            if (choferId) { syncing = true; selChofer.value = String(choferId); syncing = false }
          })
        })()
      </script>
    <% } %>
  </div>
</div>
