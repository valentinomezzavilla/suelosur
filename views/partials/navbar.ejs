<header class="app-navbar">
  <div class="d-flex align-items-center gap-2" style="min-width:0">
    <button type="button" class="navbar-toggle" id="sidebarToggle" aria-label="Abrir menú">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <h6 class="nav-title">
      <%= typeof titulo !== 'undefined' ? titulo : 'Sistema de Gestión' %>
    </h6>
  </div>
  <div class="d-flex align-items-center gap-3">
    <small class="nav-date"><%= new Date().toLocaleDateString('es-AR', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) %></small>
  </div>
</header>
