<%
  // Paginación reutilizable. Espera: page, totalPaginas, total, limit y (opcional) filtros.
  const _tp     = typeof totalPaginas !== 'undefined' ? totalPaginas : 1
  const _page   = typeof page  !== 'undefined' ? page  : 1
  const _total  = typeof total !== 'undefined' ? total : 0
  const _limit  = typeof limit !== 'undefined' ? limit : 15
  const _filtros = typeof filtros !== 'undefined' && filtros ? filtros : {}
  const _qs = (p) => {
    const base = Object.fromEntries(
      Object.entries(_filtros).filter(([k, v]) => v !== '' && v != null && k !== 'page')
    )
    return new URLSearchParams({ ...base, page: p }).toString()
  }
%>
<% if (_tp > 1) { %>
<nav class="pagination-bar">
  <small class="text-muted">
    Mostrando <%= (_page - 1) * _limit + 1 %>–<%= Math.min(_page * _limit, _total) %> de <%= _total %> registros
  </small>
  <ul class="pagination pagination-sm pagination-orange mb-0">
    <li class="page-item <%= _page <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= _qs(_page - 1) %>">‹</a>
    </li>
    <% for (let i = 1; i <= _tp; i++) { %>
      <li class="page-item <%= i === _page ? 'active' : '' %>">
        <a class="page-link" href="?<%= _qs(i) %>"><%= i %></a>
      </li>
    <% } %>
    <li class="page-item <%= _page >= _tp ? 'disabled' : '' %>">
      <a class="page-link" href="?<%= _qs(_page + 1) %>">›</a>
    </li>
  </ul>
</nav>
<% } %>
