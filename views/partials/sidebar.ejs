<%
  const ICONS = {
    plus:      '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
    store:     '<path d="M3 9l1-5h16l1 5"/><path d="M4 9v11h16V9"/><path d="M9 22V12h6v10"/>',
    calendar:  '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
    box:       '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
    truck:     '<rect x="1" y="6" width="14" height="11" rx="1"/><polygon points="15 9 19 9 22 12 22 17 15 17 15 9"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/>',
    hardhat:   '<path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v2z"/><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"/><path d="M4 15v-3a8 8 0 0 1 16 0v3"/>',
    map:       '<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>',
    users:     '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    arrowDown: '<line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>',
    arrowUp:   '<line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/>',
    cart:      '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
    dollar:    '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
    receipt:   '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
    barChart:  '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
    key:       '<circle cx="8" cy="15" r="4"/><line x1="10.85" y1="12.15" x2="19" y2="4"/><line x1="18" y1="5" x2="20" y2="7"/><line x1="15" y1="8" x2="17" y2="10"/>',
    logOut:    '<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>',
    list:      '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>',
    tool:      '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  }
  function ic(n) {
    return `<svg class="nav-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${ICONS[n]||''}</svg>`
  }
  const t = (typeof titulo !== 'undefined' ? titulo : '') || ''
  const userIniciales = (user?.nombre||'?').split(/\s+/).map(p=>p[0]).slice(0,2).join('').toUpperCase()
  const _ar = (typeof alertasResumen !== 'undefined' && alertasResumen) ? alertasResumen : null
  const _urgentes = _ar ? (_ar.vencido + _ar.critico) : 0
  const alertaBadge = () => _ar && _ar.total ? `<span class="badge rounded-pill ms-auto ${_urgentes>0?'badge-alerta':'badge-pendiente'}" style="font-size:0.65rem">${_ar.total}</span>` : ''
%>

<nav class="app-sidebar">
  <div class="sidebar-brand">
    <a href="/dashboard" class="brand-logo-link" aria-label="Ir al dashboard">
      <div class="brand-logo-wrap">
        <img src="/img/suelosurjpg.jpg" class="brand-logo-img" alt="Suelosur">
      </div>
    </a>
    <div>
      <div class="brand-name">Suelosur</div>
      <div class="brand-sub">Sistema de gestión</div>
    </div>
  </div>

  <div class="sidebar-user">
    <div class="user-avatar"><%= userIniciales %></div>
    <div class="user-info">
      <div class="user-name"><%= user?.nombre %></div>
      <div class="user-role"><%= user?.rol?.replace('_',' ') %></div>
    </div>
  </div>

  <div class="sidebar-nav">

    <% if (['admin_ventas','dueno'].includes(user?.rol)) { %>
    <div class="nav-section">
      <div class="nav-section-label">Operaciones</div>

      <div class="nav-group-label">Ventas</div>
      <a href="/ventas/cantera" class="nav-link is-indent <%= t==='Venta en Cantera'?'is-active':'' %>">
        <%- ic('store') %><span>Venta en cantera</span>
      </a>
      <a href="/ventas/viaje" class="nav-link is-indent <%= t==='Venta con Viaje'?'is-active':'' %>">
        <%- ic('truck') %><span>Venta con viaje</span>
      </a>
      <a href="/ventas" class="nav-link is-indent <%= t==='Ventas'?'is-active':'' %>">
        <%- ic('list') %><span>Historial ventas</span>
      </a>

      <div class="nav-group-label">Alquileres</div>
      <a href="/alquileres/contenedores" class="nav-link is-indent <%= t==='Alquileres — Contenedores'?'is-active':'' %>">
        <%- ic('box') %><span>Contenedores</span>
      </a>
      <a href="/alquileres/maquinaria" class="nav-link is-indent <%= t==='Alquileres — Maquinaria'?'is-active':'' %>">
        <%- ic('hardhat') %><span>Maquinaria</span>
      </a>

      <a href="/contenedores/circuito" class="nav-link <%= t==='Circuito del Día'?'is-active':'' %>">
        <%- ic('map') %><span>Circuito del día</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label">Catálogo</div>
      <a href="/contenedores" class="nav-link <%= t==='Contenedores'?'is-active':'' %>">
        <%- ic('box') %><span>Contenedores</span>
      </a>
      <a href="/maquinaria" class="nav-link <%= t==='Maquinaria'?'is-active':'' %>">
        <%- ic('hardhat') %><span>Maquinaria</span>
      </a>
      <a href="/clientes" class="nav-link <%= t==='Clientes'?'is-active':'' %>">
        <%- ic('users') %><span>Clientes</span>
      </a>
      <a href="/productos" class="nav-link <%= t==='Productos'?'is-active':'' %>">
        <%- ic('cart') %><span>Productos</span>
      </a>
      <a href="/proveedores" class="nav-link <%= t==='Proveedores'?'is-active':'' %>">
        <%- ic('store') %><span>Proveedores</span>
      </a>
      <div class="nav-group-label">Stock</div>
      <a href="/stock" class="nav-link is-indent <%= t==='Stock'?'is-active':'' %>">
        <%- ic('arrowDown') %><span>Ingreso</span>
      </a>
      <a href="/stock/egreso" class="nav-link is-indent <%= t==='Stock — Egreso'?'is-active':'' %>">
        <%- ic('arrowUp') %><span>Egreso</span>
      </a>
    </div>

    <div class="nav-section">
      <div class="nav-section-label">Finanzas</div>
      <a href="/transacciones" class="nav-link <%= t==='Transacciones'?'is-active':'' %>">
        <%- ic('receipt') %><span>Transacciones</span>
      </a>
      <a href="/clientes/cuentas" class="nav-link <%= t==='Cuentas corrientes'?'is-active':'' %>">
        <%- ic('dollar') %><span>Cuentas corrientes</span>
      </a>
      <a href="/compras" class="nav-link <%= (typeof t!=='undefined' && t && t.toLowerCase().indexOf('compra')>=0)?'is-active':'' %>">
        <%- ic('cart') %><span>Compras / Pagos</span>
      </a>
      <a href="/cheques" class="nav-link <%= t==='Cheques'||t==='Nuevo cheque'||t==='Editar cheque'?'is-active':'' %>">
        <%- ic('receipt') %><span>Cheques</span>
      </a>
    </div>
    <% } %>

    <% if (['admin_contable','dueno'].includes(user?.rol)) { %>
    <div class="nav-section">
      <div class="nav-section-label">Contabilidad</div>
      <a href="/cobranzas" class="nav-link <%= t==='Cuentas corrientes'?'is-active':'' %>">
        <%- ic('dollar') %><span>Cobranzas</span>
      </a>
      <a href="/clientes" class="nav-link <%= t==='Clientes'?'is-active':'' %>">
        <%- ic('users') %><span>Clientes</span>
      </a>
      <a href="/alertas" class="nav-link <%= t==='Centro de Alertas'?'is-active':'' %>">
        <%- ic('list') %><span>Alertas</span><%- alertaBadge() %>
      </a>
      <a href="/facturacion" class="nav-link">
        <%- ic('receipt') %><span>Facturación</span>
      </a>
    </div>
    <% } %>

    <% if (user?.rol === 'chofer') { %>
    <div class="nav-section">
      <a href="/hoja-de-ruta" class="nav-link"><%- ic('map') %><span>Mi ruta del día</span></a>
    </div>
    <% } %>

    <% if (user?.rol === 'dueno') { %>
    <div class="nav-section">
      <div class="nav-section-label">Gerencia</div>
      <a href="/dashboard" class="nav-link <%= t==='Dashboard'?'is-active':'' %>">
        <%- ic('barChart') %><span>Dashboard</span>
      </a>
      <a href="/alertas" class="nav-link <%= t==='Centro de Alertas'?'is-active':'' %>">
        <%- ic('list') %><span>Centro de Alertas</span><%- alertaBadge() %>
      </a>
      <a href="/circuitos" class="nav-link <%= t==='Circuitos Logísticos'?'is-active':'' %>">
        <%- ic('map') %><span>Circuitos</span>
      </a>
      <a href="/zonas/planificador" class="nav-link <%= t==='Planificador por zona'?'is-active':'' %>">
        <%- ic('layers') %><span>Planificador por zona</span>
      </a>
      <a href="/zonas" class="nav-link <%= t==='Zonas y tarifas'?'is-active':'' %>">
        <%- ic('map') %><span>Zonas y tarifas</span>
      </a>
      <a href="/flota" class="nav-link <%= t==='Flota Camiones'?'is-active':'' %>"><%- ic('truck') %><span>Flota camiones</span></a>
      <a href="/empleados" class="nav-link <%= t==='Flota de Personal'?'is-active':'' %>">
        <%- ic('hardhat') %><span>Flota de Personal</span>
      </a>
      <a href="/choferes" class="nav-link <%= t==='Choferes'?'is-active':'' %>">
        <%- ic('hardhat') %><span>Choferes</span>
      </a>
      <a href="/usuarios" class="nav-link <%= t==='Usuarios'?'is-active':'' %>">
        <%- ic('key') %><span>Usuarios</span>
      </a>
    </div>
    <% } %>

  </div>

  <a href="/auth/logout" class="sidebar-logout">
    <%- ic('logOut') %><span>Cerrar sesión</span>
  </a>
</nav>
