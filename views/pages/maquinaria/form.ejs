<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('truck', { size: 18 }) %> <%= titulo %></h4>
  <a href="/maquinaria" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card shadow-sm maxw-600">
  <div class="card-body">
    <form action="<%= maquina ? `/maquinaria/${maquina.id}?_method=PUT` : '/maquinaria' %>" method="POST">

      <% const estadoOpLbl = { disponible:'Disponible', en_operacion:'En operación', en_mantenimiento:'En mantenimiento', fuera_servicio:'Fuera de servicio' } %>
      <div class="row g-3 mb-3">
        <div class="col-md-2">
          <label class="form-label">N° interno</label>
          <input type="number" name="numero_interno" class="form-control" value="<%= maquina?.numero_interno || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Nombre *</label>
          <input type="text" name="nombre" class="form-control" value="<%= maquina?.nombre || '' %>" required autofocus>
        </div>
        <div class="col-md-4">
          <label class="form-label">Tipo de máquina</label>
          <select name="tipo" class="form-select">
            <% ['bobcat','minicargadora','retroexcavadora','otro'].forEach(t => { %>
              <option value="<%= t %>" <%= (maquina?.tipo||'bobcat') === t ? 'selected' : '' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-3">
          <label class="form-label">Marca</label>
          <input type="text" name="marca" class="form-control" value="<%= maquina?.marca || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Modelo</label>
          <input type="text" name="modelo" class="form-control" value="<%= maquina?.modelo || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Año</label>
          <input type="number" name="anio" class="form-control" value="<%= maquina?.anio || '' %>" min="1990" max="2030">
        </div>
        <div class="col-md-3">
          <label class="form-label">Patente</label>
          <input type="text" name="patente" class="form-control" value="<%= maquina?.patente || '' %>">
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label">Estado</label>
          <select name="estado_operativo" class="form-select">
            <% estadosOp.forEach(e => { %>
              <option value="<%= e %>" <%= (maquina?.estado_operativo||'disponible') === e ? 'selected' : '' %>><%= estadoOpLbl[e] %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Horas de uso</label>
          <input type="number" step="0.5" name="horas_uso" class="form-control" value="<%= maquina?.horas_uso || 0 %>" min="0">
        </div>
        <div class="col-md-4">
          <label class="form-label">Km actuales</label>
          <input type="number" name="km_actuales" class="form-control" value="<%= maquina?.km_actuales || 0 %>" min="0">
        </div>
        <div class="col-md-4">
          <label class="form-label">Actividad de la máquina</label>
          <select name="actividad" class="form-select">
            <option value="">— Sin definir —</option>
            <% const _actsMaq = { maquina_deposito:'Máquina - Depósito', maquina_alquiler:'Máquina - Alquiler' };
               Object.entries(_actsMaq).forEach(([v,l]) => { %>
              <option value="<%= v %>" <%= maquina?.actividad===v?'selected':'' %>><%= l %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Último mantenimiento</label>
          <input type="date" name="ultimo_service" class="form-control" value="<%= maquina?.ultimo_service || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Próximo mantenimiento</label>
          <input type="date" name="proximo_service" class="form-control" value="<%= maquina?.proximo_service || '' %>">
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label">Observaciones</label>
        <textarea name="observaciones" class="form-control" rows="2"><%= maquina?.observaciones || '' %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-naranja px-4"><%= maquina ? 'Guardar cambios' : 'Crear máquina' %></button>
        <a href="/maquinaria" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
