<%
  const labelEstado = { en_planta:'En planta', despachada:'Despachada', en_uso:'En uso', a_retirar:'A retirar', en_servicio:'En servicio' }
  const badgeEstado = { en_planta:'badge-activo', despachada:'badge-en-transito', en_uso:'badge-en-transito', a_retirar:'badge-alerta', en_servicio:'badge-pendiente' }
  const ultimo = maquina.movimientos[0]
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-0 text-dark-title">🚜 <%= maquina.nombre %></h4>
    <small class="text-muted"><%= maquina.tipo %> · <%= maquina.patente || 'sin patente' %></small>
  </div>
  <div class="d-flex gap-2">
    <a href="/maquinaria/<%= maquina.id %>/editar" class="btn btn-sm btn-outline-secondary">✏️ Editar</a>
    <a href="/maquinaria" class="btn btn-sm btn-outline-secondary">← Volver</a>
  </div>
</div>

<div class="row g-4">

  <!-- Estado actual -->
  <div class="col-md-4">
    <div class="card shadow-sm h-100 card-accent-orange">
      <div class="card-body text-center">
        <p class="text-muted small mb-2">Estado actual</p>
        <% if (ultimo) { %>
          <h4><span class="badge rounded-pill px-3 py-2 <%= badgeEstado[ultimo.estado_paso] || 'badge-pendiente' %>"><%= labelEstado[ultimo.estado_paso] || ultimo.estado_paso %></span></h4>
          <small class="text-muted">desde <%= ultimo.fecha_movimiento %></small>
          <% if (ultimo.cliente_nombre) { %>
            <hr><p class="mb-1 fw-semibold"><%= ultimo.cliente_nombre %></p>
            <small class="text-muted">OP-<%= String(ultimo.nro_op).padStart(4,'0') %></small><br>
            <small class="text-muted">📍 <%= ultimo.domicilio_entrega %></small>
          <% } %>
        <% } else { %>
          <p class="text-muted">Sin movimientos.</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Registrar movimiento -->
  <div class="col-md-8">
    <div class="card shadow-sm h-100">
      <div class="card-header card-header-light">Registrar movimiento</div>
      <div class="card-body">
        <form action="/maquinaria/<%= maquina.id %>/movimiento" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Nuevo estado *</label>
              <select name="estado_paso" class="form-select" required>
                <option value="">Seleccionar...</option>
                <% Object.entries(labelEstado).forEach(([k,v]) => { %>
                  <option value="<%= k %>"><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Operario</label>
              <select name="id_operario" class="form-select">
                <option value="">— sin operario —</option>
                <% operarios.forEach(o => { %><option value="<%= o.id %>"><%= o.nombre %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Horas trabajadas</label>
              <input type="number" name="horas_trabajadas" class="form-control" step="0.5" min="0" value="0">
            </div>
            <div class="col-md-4">
              <label class="form-label">Km registrados</label>
              <input type="number" name="km_registrados" class="form-control" min="0" value="0">
            </div>
            <div class="col-md-4">
              <label class="form-label">Fecha y hora</label>
              <input type="datetime-local" name="fecha_movimiento" class="form-control">
            </div>
            <div class="col-12">
              <label class="form-label">Observaciones</label>
              <input type="text" name="observaciones" class="form-control" placeholder="Notas opcionales...">
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn btn-naranja">Registrar movimiento</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Registrar mantenimiento -->
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header card-header-light d-flex justify-content-between">
        <span>Registrar mantenimiento</span>
        <% if (maquina.proximo_service) { %><small class="text-muted">Próximo: <%= maquina.proximo_service %></small><% } %>
      </div>
      <div class="card-body">
        <form action="/maquinaria/<%= maquina.id %>/mantenimiento" method="POST">
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label">Tipo</label>
              <select name="tipo_service" class="form-select">
                <option value="preventivo">Preventivo</option>
                <option value="correctivo">Correctivo</option>
                <option value="revision">Revisión</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Fecha *</label>
              <input type="date" name="fecha" class="form-control" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Costo ($)</label>
              <input type="number" name="costo" class="form-control" step="0.01" min="0">
            </div>
            <div class="col-md-3">
              <label class="form-label">Km al service</label>
              <input type="number" name="km_al_service" class="form-control" min="0" value="<%= maquina.km_actuales || 0 %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Próximo service</label>
              <input type="date" name="proximo_fecha" class="form-control">
            </div>
            <div class="col-md-3">
              <label class="form-label">Taller</label>
              <input type="text" name="taller" class="form-control">
            </div>
            <div class="col-md-6">
              <label class="form-label">Descripción</label>
              <input type="text" name="descripcion" class="form-control" placeholder="Qué se hizo...">
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn btn-naranja">Registrar</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Historial de movimientos -->
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header card-header-light">Historial de movimientos (<%= maquina.movimientos.length %>)</div>
      <div class="card-body p-0">
        <% if (!maquina.movimientos.length) { %>
          <p class="text-muted text-center py-4 mb-0">Sin movimientos.</p>
        <% } else { %>
        <table class="table table-hover align-middle mb-0">
          <thead><tr><th>Fecha</th><th>Estado</th><th>Operario</th><th>Horas</th><th>Observaciones</th></tr></thead>
          <tbody>
            <% maquina.movimientos.forEach(m => { %>
            <tr>
              <td><small class="text-muted"><%= m.fecha_movimiento %></small></td>
              <td><span class="badge rounded-pill px-3 <%= badgeEstado[m.estado_paso] || 'badge-pendiente' %>"><%= labelEstado[m.estado_paso] || m.estado_paso %></span></td>
              <td><small><%= m.operario_nombre || '—' %></small></td>
              <td><small><%= m.horas_trabajadas > 0 ? m.horas_trabajadas + 'h' : '—' %></small></td>
              <td><small class="text-muted"><%= m.observaciones || '—' %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Historial de mantenimientos -->
  <% if (maquina.mantenimientos?.length) { %>
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header card-header-light">Historial de mantenimientos</div>
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead><tr><th>Fecha</th><th>Tipo</th><th>Costo</th><th>Taller</th><th>Descripción</th><th>Próximo</th></tr></thead>
          <tbody>
            <% maquina.mantenimientos.forEach(m => { %>
            <tr>
              <td><small><%= m.fecha %></small></td>
              <td><span class="badge badge-pendiente px-2"><%= m.tipo_service %></span></td>
              <td><small>$<%= (m.costo||0).toLocaleString('es-AR') %></small></td>
              <td><small class="text-muted"><%= m.taller || '—' %></small></td>
              <td><small class="text-muted"><%= m.descripcion || '—' %></small></td>
              <td><small class="text-muted"><%= m.proximo_fecha || '—' %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% } %>

</div>
