<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('users', { size: 18 }) %> Clientes</h4>
  <div class="d-flex gap-2">
    <a href="/clientes/cuentas" class="btn btn-sm btn-outline-secondary"><%- icon('chart', { size: 15 }) %> Cuentas corrientes</a>
    <a href="/clientes/nuevo" class="btn btn-naranja">+ Nuevo Cliente</a>
  </div>
</div>

<%- include('../../partials/tabla_toolbar', {
  action: '/clientes',
  placeholder: 'Buscar por #, nombre, apellido o DNI...',
  qValue: filtros.q,
  hiddenFilters: { sort: filtros.sort, dir: filtros.dir },
  filtros: [
    { name: 'tipo', label: 'Tipo de cliente', selected: filtros.tipo, options: [
      { value: 'Empresa', label: 'Empresa' },
      { value: 'Particular', label: 'Particular' },
      { value: 'Obra', label: 'Obra' },
    ]},
    { name: 'cuentaCorriente', label: 'Cuenta corriente', selected: filtros.cuentaCorriente, options: [
      { value: 'si', label: 'Con cuenta corriente' },
      { value: 'no', label: 'Sin cuenta corriente' },
    ]},
  ],
}) %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!clientes.length) { %>
      <%- include('../../partials/empty_state', { icono: '👥', mensaje: filtros.q || filtros.tipo || filtros.cuentaCorriente ? 'No hay clientes que coincidan con tu búsqueda.' : 'Aún no hay datos para mostrar.', accionHref: '/clientes/nuevo', accionLabel: 'Crear primer cliente' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <%- include('../../partials/th_sort', { sortKey: 'numero',   sortLabel: '#',          currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <%- include('../../partials/th_sort', { sortKey: 'nombre',   sortLabel: 'Nombre',     currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <%- include('../../partials/th_sort', { sortKey: 'apellido', sortLabel: 'Apellido',   currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <th>Tipo</th>
          <th>Zona</th>
          <%- include('../../partials/th_sort', { sortKey: 'telefono', sortLabel: 'WhatsApp',   currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <th>Domicilio</th>
          <%- include('../../partials/th_sort', { sortKey: 'saldo',    sortLabel: 'Saldo',      currentSort: filtros.sort, currentDir: filtros.dir, filtros, align: 'right' }) %>
          <th class="text-center">Estado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% clientes.forEach(c => { %>
        <tr class="<%= !c.activo ? 'text-muted' : '' %>">
          <td class="fw-semibold text-orange">#<%= c.numero %></td>
          <td class="fw-semibold"><%= c.nombre %></td>
          <td><%= c.apellido || '' %></td>
          <td><small class="text-muted"><%= c.tipo_cliente || '—' %></small></td>
          <td><small class="text-muted"><%= c.zona || '—' %></small></td>
          <td><small><%= c.tel_whatsapp || '—' %></small></td>
          <td><small class="text-muted"><%= c.domicilio_ppal || '—' %></small></td>
          <td class="text-end">
            <% const s = Number(c.saldo || 0) %>
            <% if (s < 0) { %>
              <span class="text-danger fw-semibold">$<%= Math.abs(s).toLocaleString('es-AR') %></span>
            <% } else if (s > 0) { %>
              <span class="text-success fw-semibold">$<%= s.toLocaleString('es-AR') %></span>
            <% } else { %>
              <span class="text-muted">$0</span>
            <% } %>
          </td>
          <td class="text-center">
            <% if (c.activo) { %>
              <span class="badge rounded-pill px-3 badge-activo">Activo</span>
            <% } else { %>
              <span class="badge rounded-pill px-3 badge-alerta">Inactivo</span>
            <% } %>
          </td>
          <td class="text-center">
            <a href="/clientes/<%= c.id %>/reporte" class="btn btn-sm btn-outline-primary" title="Generar reporte PDF"><%- icon('fileText', { size: 15 }) %></a>
            <a href="/clientes/<%= c.id %>/editar" class="btn btn-sm btn-outline-secondary" title="Editar"><%- icon('edit', { size: 15 }) %></a>
            <% if (c.activo) { %>
              <form action="/clientes/<%= c.id %>/eliminar" method="POST" class="d-inline"
                    onsubmit="return confirm('¿Eliminar a <%= c.nombre %> <%= c.apellido %>? Se da de baja (baja lógica) y se conserva el historial.')">
                <button class="btn btn-sm btn-outline-danger" title="Eliminar"><%- icon('trash', { size: 15 }) %></button>
              </form>
            <% } else { %>
              <form action="/clientes/<%= c.id %>/toggle" method="POST" class="d-inline">
                <button class="btn btn-sm btn-outline-success" title="Reactivar"><%- icon('check', { size: 15 }) %></button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <%- include('../../partials/paginacion', { page, totalPaginas, total, limit, filtros }) %>
    <% } %>
  </div>
</div>
