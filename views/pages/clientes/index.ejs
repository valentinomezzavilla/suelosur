<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0 text-dark-title">👥 Clientes</h4>
  <a href="/clientes/nuevo" class="btn btn-naranja">+ Nuevo Cliente</a>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!clientes.length) { %>
      <%- include('../../partials/empty_state', { icono: '👥', mensaje: 'Aún no hay datos para mostrar.', accionHref: '/clientes/nuevo', accionLabel: 'Crear primer cliente' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th class="col-w-50">#</th>
          <th>Nombre</th>
          <th>Tipo</th>
          <th>Zona</th>
          <th>WhatsApp</th>
          <th>Domicilio</th>
          <th class="text-center">Estado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% clientes.forEach(c => { %>
        <tr class="<%= !c.activo ? 'text-muted' : '' %>">
          <td class="fw-bold text-orange">#<%= c.numero %></td>
          <td class="fw-semibold"><%= c.nombre %> <%= c.apellido %></td>
          <td><small class="text-muted"><%= c.tipo_cliente || '—' %></small></td>
          <td><small class="text-muted"><%= c.zona || '—' %></small></td>
          <td><small><%= c.tel_whatsapp || '—' %></small></td>
          <td><small class="text-muted"><%= c.domicilio_ppal || '—' %></small></td>
          <td class="text-center">
            <% if (c.activo) { %>
              <span class="badge rounded-pill px-3 badge-activo">Activo</span>
            <% } else { %>
              <span class="badge rounded-pill px-3 badge-alerta">Inactivo</span>
            <% } %>
          </td>
          <td class="text-center">
            <a href="/clientes/<%= c.id %>/editar" class="btn btn-sm btn-outline-secondary">✏️</a>
            <form action="/clientes/<%= c.id %>/toggle" method="POST" class="d-inline">
              <button class="btn btn-sm <%= c.activo ? 'btn-outline-danger' : 'btn-outline-success' %>"
                      title="<%= c.activo ? 'Desactivar' : 'Activar' %>">
                <%= c.activo ? '🚫' : '✅' %>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <%- include('../../partials/paginacion', { page, totalPaginas, total, limit, filtros }) %>
    <% } %>
  </div>
</div>
