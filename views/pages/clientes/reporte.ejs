<div class="page-header">
  <div>
    <a href="/clientes" class="back-link">← Clientes</a>
    <h1 class="page-title">Reporte de cliente</h1>
    <small class="text-muted">
      #<%= cliente.numero || '—' %> · <%= cliente.nombre %> <%= cliente.apellido || '' %>
      <% if (cliente.dni) { %>· DNI <%= cliente.dni %><% } %>
    </small>
  </div>
</div>

<div class="config-page">
  <%# Reporte = libro de ventas de este cliente (mismas columnas que el reporte de ventas) %>
  <form method="GET" class="config-form">
    <input type="hidden" name="clienteId" value="<%= cliente.id %>">

    <div class="form-section">
      <h3 class="form-section__title">Período</h3>
      <p class="form-hint">Dejá vacío para incluir todo el historial. El reporte lista las ventas del cliente por renglón: fecha, remito, cantidad, código, material, obra, precio unitario e importe.</p>
      <div class="form-row-2">
        <div class="form-group">
          <label for="fechaDesde">Desde</label>
          <input type="date" name="desde" id="fechaDesde" value="<%= filtros.fechaDesde || '' %>">
        </div>
        <div class="form-group">
          <label for="fechaHasta">Hasta</label>
          <input type="date" name="hasta" id="fechaHasta" value="<%= filtros.fechaHasta || '' %>">
        </div>
      </div>
      <div class="form-row-2" style="margin-top:0.5rem">
        <button type="button" class="btn-secondary btn-sm" onclick="setPreset('mes')">Mes actual</button>
        <button type="button" class="btn-secondary btn-sm" onclick="setPreset('anio')">Año actual</button>
      </div>
    </div>

    <div class="config-actions">
      <button type="submit" formaction="/ventas/libro/pdf" formtarget="_blank" class="btn-primary"><%- icon('fileText', { size: 15 }) %> Generar reporte PDF</button>
      <button type="submit" formaction="/ventas/libro/excel" class="btn-secondary"><%- icon('download', { size: 15 }) %> Excel</button>
      <a href="/clientes/<%= cliente.id %>" class="btn-secondary">Volver</a>
    </div>
  </form>
</div>

<script>
  function setPreset(p) {
    const hoy = new Date()
    const desde = document.getElementById('fechaDesde')
    const hasta = document.getElementById('fechaHasta')
    const fmt = d => d.toISOString().slice(0, 10)
    if (p === 'mes') {
      desde.value = fmt(new Date(hoy.getFullYear(), hoy.getMonth(), 1))
      hasta.value = fmt(new Date(hoy.getFullYear(), hoy.getMonth() + 1, 0))
    } else if (p === 'anio') {
      desde.value = fmt(new Date(hoy.getFullYear(), 0, 1))
      hasta.value = fmt(new Date(hoy.getFullYear(), 11, 31))
    }
  }
</script>
