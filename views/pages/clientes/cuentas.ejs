<%
  const money = (n) => '$' + Number(n || 0).toLocaleString('es-AR')
  const totalDeuda  = conCuenta.filter(c => c.saldo < 0).reduce((a, c) => a + Math.abs(c.saldo), 0)
  const totalAFavor = conCuenta.filter(c => c.saldo > 0).reduce((a, c) => a + c.saldo, 0)
  const conDeuda    = conCuenta.filter(c => c.saldo < 0).length
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('chart', { size: 18 }) %> Cuentas corrientes</h4>
  <a href="/clientes" class="btn btn-sm btn-outline-secondary">← Clientes</a>
</div>

<!-- Métricas -->
<div class="stat-cards" style="grid-template-columns:repeat(3,minmax(0,1fr));max-width:760px">
  <div class="stat-card stat-card--danger">
    <div class="stat-card__icon"><%- icon('alert', { size: 20 }) %></div>
    <div class="stat-card__body"><span class="stat-card__value"><%= money(totalDeuda) %></span><span class="stat-card__label">Deuda total · <%= conDeuda %> cliente(s)</span></div>
  </div>
  <div class="stat-card stat-card--success">
    <div class="stat-card__icon"><%- icon('checkCircle', { size: 20 }) %></div>
    <div class="stat-card__body"><span class="stat-card__value"><%= money(totalAFavor) %></span><span class="stat-card__label">Saldo a favor</span></div>
  </div>
  <div class="stat-card stat-card--info">
    <div class="stat-card__icon"><%- icon('users', { size: 20 }) %></div>
    <div class="stat-card__body"><span class="stat-card__value"><%= conCuenta.length %></span><span class="stat-card__label">Cuentas habilitadas</span></div>
  </div>
</div>

<!-- Cuentas habilitadas -->
<div class="card shadow-sm mb-4">
  <div class="card-header bg-white fw-semibold">Cuentas habilitadas</div>
  <div class="card-body p-0">
    <% if (!conCuenta.length) { %>
      <%- include('../../partials/empty_state', { icono: '💳', mensaje: 'No hay cuentas corrientes habilitadas aún.', accionHref: '/clientes', accionLabel: 'Ir a clientes' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th class="col-w-50">#</th>
          <th>Cliente</th>
          <th>Teléfono</th>
          <th class="text-end">Saldo</th>
          <th class="text-center">Movim.</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% conCuenta.forEach(c => { %>
        <tr>
          <td class="fw-semibold text-orange">#<%= c.numero %></td>
          <td class="fw-semibold"><%= c.nombre %> <%= c.apellido %></td>
          <td><small class="text-muted"><%= c.telefono || '—' %></small></td>
          <td class="text-end">
            <% if (c.saldo < 0) { %>
              <span class="fw-bold text-danger">Debe $<%= Math.abs(c.saldo).toLocaleString('es-AR') %></span>
            <% } else if (c.saldo > 0) { %>
              <span class="fw-bold text-success">A favor $<%= c.saldo.toLocaleString('es-AR') %></span>
            <% } else { %>
              <span class="badge rounded-pill px-3 badge-activo">Al día</span>
            <% } %>
          </td>
          <td class="text-center"><small class="text-muted"><%= c.movimientos.length %></small></td>
          <td class="text-center">
            <a href="/clientes/cuentas/<%= c.id %>" class="btn btn-sm btn-outline-secondary">Estado de cuenta</a>
            <% if (c.saldo < 0) { %>
              <button type="button" class="btn btn-sm btn-success btn-abonar"
                      data-id="<%= c.id %>" data-nombre="<%= c.nombre %> <%= c.apellido %>"
                      data-deuda="<%= Math.abs(c.saldo) %>">Saldar</button>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<!-- Habilitar cuenta a clientes sin CC -->
<div class="card shadow-sm">
  <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
    <span>Habilitar cuenta corriente</span>
    <small class="text-muted">Clientes sin cuenta habilitada</small>
  </div>
  <div class="card-body p-0">
    <% if (!sinCuenta.length) { %>
      <div class="p-4 text-center text-muted">Todos los clientes activos ya tienen cuenta corriente habilitada.</div>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th class="col-w-50">#</th>
          <th>Cliente</th>
          <th>Teléfono</th>
          <th>Email</th>
          <th class="text-center">Acción</th>
        </tr>
      </thead>
      <tbody>
        <% sinCuenta.forEach(c => { %>
        <tr>
          <td class="fw-semibold text-orange">#<%= c.numero %></td>
          <td class="fw-semibold"><%= c.nombre %> <%= c.apellido %></td>
          <td><small class="text-muted"><%= c.telefono || '—' %></small></td>
          <td><small class="text-muted"><%= c.email || '—' %></small></td>
          <td class="text-center">
            <form action="/clientes/<%= c.id %>/habilitar-cuenta" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-success">+ Habilitar</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<!-- Modal abonar -->
<div id="modal-abonar" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <div class="modal-header">
      <h2 class="modal-title">Saldar deuda — <span id="modal-abonar-nombre"></span></h2>
      <button type="button" class="modal-close" id="cerrarModalAbonar">✕</button>
    </div>
    <p style="margin:0.75rem 0 0.25rem; font-size:0.9rem; color:#64748b">
      Deuda total: <strong id="modal-abonar-deuda"></strong>
    </p>
    <form id="formAbonar" method="POST" style="margin-top:1rem">
      <div class="form-group">
        <label for="inputMonto">Monto a abonar</label>
        <input type="number" name="monto" id="inputMonto" min="1" step="1" required placeholder="Ej: 15000">
      </div>
      <div class="modal-actions" style="margin-top:1rem">
        <button type="submit" class="btn btn-success">Confirmar pago</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnPagarTotal">Pagar total</button>
        <button type="button" class="btn btn-outline-secondary" id="cancelarModalAbonar">Cancelar</button>
      </div>
    </form>
  </div>
</div>
