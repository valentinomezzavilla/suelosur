<%
  const money = (n) => '$' + Number(n || 0).toLocaleString('es-AR')
  const nombre = `${cliente.nombre} ${cliente.apellido || ''}`.trim()
  const presetHref = (p) => '/clientes/cuentas/' + cliente.id + '?preset=' + p
  const tipoLabel = { deuda: 'Cargo', pago: 'Pago', ajuste: 'Ajuste' }
  const saldoTxt = (s) => s < 0 ? `Debe ${money(Math.abs(s))}` : (s > 0 ? `A favor ${money(s)}` : 'Al día')
  const saldoCls = (s) => s < 0 ? 'text-danger' : (s > 0 ? 'text-success' : 'text-muted')
  const qsPdf = new URLSearchParams(
    Object.entries({ preset: filtros.preset, fechaDesde: filtros.fechaDesde, fechaHasta: filtros.fechaHasta }).filter(([,v]) => v)
  ).toString()
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <a href="/clientes/cuentas" class="text-muted small text-decoration-none">← Cuentas corrientes</a>
    <h4 class="fw-bold mb-0 text-dark-title">
      <%- icon('chart', { size: 18 }) %> Cuenta corriente — <%= nombre %>
    </h4>
  </div>
  <div class="d-flex gap-2">
    <a href="/clientes/cuentas/<%= cliente.id %>/pdf<%= qsPdf ? '?' + qsPdf : '' %>" target="_blank" class="btn btn-sm btn-outline-secondary">
      <%- icon('printer', { size: 15 }) %> Descargar PDF
    </a>
    <% if (cliente.saldo < 0) { %>
      <button type="button" class="btn btn-success btn-abonar"
              data-id="<%= cliente.id %>" data-nombre="<%= nombre %>"
              data-deuda="<%= Math.abs(cliente.saldo) %>">Saldar deuda total</button>
    <% } %>
    <form action="/clientes/<%= cliente.id %>/deshabilitar-cuenta" method="POST" class="d-inline"
          onsubmit="return confirm('¿Deshabilitar la cuenta corriente de <%= nombre %>? El historial se conserva.')">
      <button type="submit" class="btn btn-sm btn-outline-danger">Deshabilitar cuenta</button>
    </form>
  </div>
</div>

<!-- Saldo actual -->
<div class="card shadow-sm mb-3">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <div class="text-muted small">Saldo actual</div>
      <div class="fs-4 fw-bold <%= saldoCls(cliente.saldo) %>"><%= saldoTxt(cliente.saldo) %></div>
    </div>
    <div class="text-end">
      <span class="badge rounded-pill px-3 badge-activo">Cuenta habilitada</span>
    </div>
  </div>
</div>

<!-- Período -->
<div class="periodo-chips">
  <a href="<%= presetHref('hoy') %>"    class="periodo-chip <%= filtros.preset==='hoy'    ? 'is-active' : '' %>">Hoy</a>
  <a href="<%= presetHref('semana') %>" class="periodo-chip <%= filtros.preset==='semana' ? 'is-active' : '' %>">Esta semana</a>
  <a href="<%= presetHref('mes') %>"    class="periodo-chip <%= filtros.preset==='mes'    ? 'is-active' : '' %>">Este mes</a>
</div>

<form method="GET" action="/clientes/cuentas/<%= cliente.id %>" class="card shadow-sm mb-3">
  <div class="card-body py-2">
    <input type="hidden" name="preset" value="rango">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Desde</label>
        <input type="date" name="fechaDesde" value="<%= filtros.fechaDesde || '' %>" class="form-control form-control-sm">
      </div>
      <div class="col-md-3">
        <label class="form-label">Hasta</label>
        <input type="date" name="fechaHasta" value="<%= filtros.fechaHasta || '' %>" class="form-control form-control-sm">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-naranja">Filtrar</button>
        <a href="/clientes/cuentas/<%= cliente.id %>" class="btn btn-sm btn-outline-secondary ms-1">Limpiar</a>
      </div>
    </div>
  </div>
</form>

<!-- Resumen del período -->
<div class="stat-cards" style="grid-template-columns:repeat(4,minmax(0,1fr))">
  <div class="stat-card stat-card--neutral">
    <div class="stat-card__body"><span class="stat-card__value"><%= money(estado.saldoInicial) %></span><span class="stat-card__label">Saldo inicial</span></div>
  </div>
  <div class="stat-card stat-card--danger">
    <div class="stat-card__body"><span class="stat-card__value"><%= money(estado.debitos) %></span><span class="stat-card__label">Débitos (cargos)</span></div>
  </div>
  <div class="stat-card stat-card--success">
    <div class="stat-card__body"><span class="stat-card__value"><%= money(estado.creditos) %></span><span class="stat-card__label">Créditos (pagos)</span></div>
  </div>
  <div class="stat-card stat-card--info">
    <div class="stat-card__body"><span class="stat-card__value <%= saldoCls(estado.saldoFinal) %>"><%= money(estado.saldoFinal) %></span><span class="stat-card__label">Saldo final · <%= periodoLabel %></span></div>
  </div>
</div>

<!-- Registrar movimiento -->
<div class="card shadow-sm mb-3">
  <div class="card-header bg-white fw-semibold">Registrar movimiento</div>
  <div class="card-body">
    <form action="/clientes/<%= cliente.id %>/cuenta/movimiento" method="POST">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Tipo</label>
          <select name="clase" class="form-select form-select-sm">
            <option value="pago">Pago / abono</option>
            <option value="cargo">Cargo / deuda</option>
            <option value="ajuste">Ajuste a favor</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Monto</label>
          <input type="number" name="monto" min="1" step="1" class="form-control form-control-sm" placeholder="Ej: 15000" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Descripción</label>
          <input type="text" name="descripcion" class="form-control form-control-sm" placeholder="(opcional)">
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-sm btn-naranja">Registrar</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Ledger -->
<div class="card shadow-sm">
  <div class="card-header bg-white fw-semibold">Movimientos del período</div>
  <div class="card-body p-0">
    <% if (!estado.movimientos.length) { %>
      <div class="p-4 text-center text-muted">Sin movimientos en el período seleccionado.</div>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Fecha</th>
          <th>Tipo</th>
          <th>Descripción</th>
          <th class="text-end">Débito</th>
          <th class="text-end">Crédito</th>
          <th class="text-end">Saldo</th>
        </tr>
      </thead>
      <tbody>
        <% if (filtros.fechaDesde) { %>
        <tr class="table-light">
          <td colspan="5" class="text-muted small">Saldo inicial</td>
          <td class="text-end fw-semibold <%= saldoCls(estado.saldoInicial) %>"><%= money(estado.saldoInicial) %></td>
        </tr>
        <% } %>
        <% estado.movimientos.forEach(m => { %>
        <tr>
          <td><small class="text-muted"><%= formatFechaHora(m.created_at) %></small></td>
          <td>
            <% if (m.tipo === 'deuda') { %><span class="badge rounded-pill px-3 badge-alerta">Cargo</span>
            <% } else if (m.tipo === 'pago') { %><span class="badge rounded-pill px-3 badge-activo">Pago</span>
            <% } else { %><span class="badge rounded-pill px-3 badge-pendiente">Ajuste</span><% } %>
          </td>
          <td><%= m.descripcion %></td>
          <td class="text-end text-danger"><%= m.monto < 0 ? money(Math.abs(m.monto)) : '—' %></td>
          <td class="text-end text-success"><%= m.monto > 0 ? money(m.monto) : '—' %></td>
          <td class="text-end fw-semibold <%= saldoCls(m.saldo) %>"><%= money(m.saldo) %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr class="table-light">
          <td colspan="3" class="fw-semibold">Totales del período</td>
          <td class="text-end fw-bold text-danger"><%= money(estado.debitos) %></td>
          <td class="text-end fw-bold text-success"><%= money(estado.creditos) %></td>
          <td class="text-end fw-bold <%= saldoCls(estado.saldoFinal) %>"><%= money(estado.saldoFinal) %></td>
        </tr>
      </tfoot>
    </table>
    <% } %>
  </div>
</div>

<!-- Modal abonar -->
<div id="modal-abonar" class="modal-overlay" style="display:none">
  <div class="modal-box">
    <div class="modal-header">
      <h2 class="modal-title">Saldar deuda — <span id="modal-abonar-nombre"></span></h2>
      <button type="button" class="modal-close" id="cerrarModalAbonar">✕</button>
    </div>
    <p style="margin:0.75rem 0 0.25rem; font-size:0.9rem; color:#64748b">
      Deuda total: <strong id="modal-abonar-deuda"></strong>
    </p>
    <form id="formAbonar" method="POST" style="margin-top:1rem">
      <div class="form-group">
        <label for="inputMonto">Monto a abonar</label>
        <input type="number" name="monto" id="inputMonto" min="1" step="1" required placeholder="Ej: 15000">
      </div>
      <div class="modal-actions" style="margin-top:1rem">
        <button type="submit" class="btn btn-success">Confirmar pago</button>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="btnPagarTotal">Pagar total</button>
        <button type="button" class="btn btn-outline-secondary" id="cancelarModalAbonar">Cancelar</button>
      </div>
    </form>
  </div>
</div>
