<%
  const badge = { pendiente:'badge-pendiente', despachado:'badge-en-transito' }
  const lbl = { pendiente:'Pendiente', despachado:'En tránsito' }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0 text-dark-title"><%- icon('map', { size: 18 }) %> Mi ruta del día</h4>
    <% if (empleado) { %><small class="text-muted"><%= empleado.nombre %> <%= empleado.apellido %></small><% } %>
  </div>
  <span class="badge rounded-pill px-3 badge-activo"><%= paradas.length %> parada(s)</span>
</div>

<% if (!empleado) { %>
  <div class="card shadow-sm"><div class="card-body text-center py-5">
    <div style="font-size:2rem">🪪</div>
    <p class="fw-semibold mb-1">Tu usuario no está vinculado a un empleado</p>
    <p class="text-muted small mb-0">Pedile al administrador que vincule tu cuenta con tu legajo para ver tus rutas asignadas.</p>
  </div></div>
<% } else if (!paradas.length) { %>
  <div class="card shadow-sm"><div class="card-body text-center py-5">
    <div style="font-size:2rem">✅</div>
    <p class="fw-semibold mb-1">No tenés operaciones asignadas pendientes</p>
    <p class="text-muted small mb-0">Cuando te asignen entregas o retiros, van a aparecer acá.</p>
  </div></div>
<% } else { %>
  <div class="d-flex flex-column gap-2">
    <% paradas.forEach((p, i) => { %>
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <span class="badge rounded-pill px-3 <%= badge[p.estado] || 'badge-pendiente' %>"><%= lbl[p.estado] || p.estado %></span>
            <span class="badge rounded-pill px-3 badge-rol ms-1"><%= p.tipoLabel %></span>
            <span class="fw-bold ms-2">OP-<%= String(p.nro_op).padStart(4,'0') %></span>
          </div>
          <% if (p.fecha_entrega_planificada) { %><small class="text-muted"><%- icon('clock', {size:13}) %> <%= formatFecha(p.fecha_entrega_planificada) %></small><% } %>
        </div>
        <p class="fw-semibold mb-1 mt-2"><%= p.cliente_nombre %><% if (p.tel_whatsapp) { %> <small class="text-muted">· <%= p.tel_whatsapp %></small><% } %></p>
        <p class="mb-1">📍 <%= p.domicilio || 'Domicilio a coordinar' %></p>
        <% if (p.camion_patente || p.camion_nombre) { %><p class="text-muted small mb-1">🚚 <%= [p.camion_nombre, p.camion_patente].filter(Boolean).join(' · ') %></p><% } %>
        <% if (p.observaciones) { %><p class="text-muted small mb-0"><%= p.observaciones %></p><% } %>
      </div>
    </div>
    <% }) %>
  </div>
<% } %>
