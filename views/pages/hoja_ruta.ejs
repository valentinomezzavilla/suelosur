<%
  const faseBadge = { por_iniciar:'badge-pendiente', en_curso:'badge-en-transito', en_servicio:'badge-activo' }
  // HOY: tareas no programadas a futuro y que NO estén en servicio (los en servicio van a su tabla aparte)
  const pendientes = (typeof hoy !== 'undefined' ? hoy : tareas).filter(t => t.fase !== 'en_servicio')
  const enServicio = (typeof hoy !== 'undefined' ? hoy : tareas).filter(t => t.fase === 'en_servicio')
  const proximosList = typeof proximos !== 'undefined' ? proximos : []
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0 text-dark-title"><%- icon('map', { size: 18 }) %> Mi ruta del día</h4>
    <% if (empleado) { %><small class="text-muted"><%= empleado.nombre %> <%= empleado.apellido %></small><% } %>
  </div>
  <div class="text-end">
    <span class="badge rounded-pill px-3 badge-activo"><%= pendientes.length %> hoy</span>
    <% if (proximosList.length) { %><span class="badge rounded-pill px-3 badge-pendiente ms-1"><%= proximosList.length %> próximos</span><% } %>
  </div>
</div>

<% if (!empleado) { %>
  <div class="card shadow-sm"><div class="card-body text-center py-5">
    <div style="font-size:2rem">🪪</div>
    <p class="fw-semibold mb-1">Tu usuario no está vinculado a un empleado</p>
    <p class="text-muted small mb-0">Pedile al administrador que vincule tu cuenta con tu legajo para ver tus tareas.</p>
  </div></div>
<% } else { %>

  <% if (hayEnCurso) { %>
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
      <span style="font-size:1.2rem">⏳</span>
      <span>Tenés una <strong>tarea en curso</strong>. Finalizala antes de iniciar otra.</span>
    </div>
  <% } %>

  <!-- ── HOY ─────────────────────────────────────────────────── -->
  <h5 class="fw-bold mb-2 mt-3">📅 Hoy</h5>
  <% if (!pendientes.length) { %>
    <div class="card shadow-sm mb-3"><div class="card-body text-center py-4">
      <div style="font-size:2rem">✅</div>
      <p class="fw-semibold mb-1">No tenés tareas para hoy</p>
      <p class="text-muted small mb-0">Cuando te asignen viajes o contenedores para hoy, van a aparecer acá.</p>
    </div></div>
  <% } else { %>
    <div class="d-flex flex-column gap-2 mb-3">
      <% pendientes.forEach(t => { %>
      <div class="card shadow-sm <%= t.fase==='en_curso' ? 'border-start border-4 border-warning' : '' %>">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
              <span style="font-size:1.1rem"><%= t.icono %></span>
              <span class="fw-bold ms-1"><%= t.titulo %></span>
              <span class="badge rounded-pill px-3 <%= faseBadge[t.fase] %> ms-2"><%= t.detalleFase %></span>
              <span class="text-muted ms-2">OP-<%= String(t.nro_op).padStart(4,'0') %></span>
            </div>
            <% if (t.fecha) { %><small class="text-muted"><%- icon('clock',{size:13}) %> <%= formatFecha(t.fecha) %></small><% } %>
          </div>

          <p class="fw-semibold mb-1 mt-2"><%= t.cliente %><% if (t.tel) { %> <small class="text-muted">· <%= t.tel %></small><% } %></p>
          <p class="mb-1">📍 <%= t.domicilio || 'Domicilio a coordinar' %></p>
          <% if (t.contenedor) { %><p class="text-muted small mb-1">Contenedor N° <%= t.contenedor %></p><% } %>
          <% if (t.camion) { %><p class="text-muted small mb-1">🚚 <%= t.camion %></p><% } %>
          <% if (t.sinContenedor) { %><p class="text-danger small mb-1">⚠️ Sin contenedor asignado todavía.</p><% } %>
          <% if (t.observaciones) { %><p class="text-muted small mb-1"><%= t.observaciones %></p><% } %>

          <!-- Ver remito (siempre disponible para revisarlo antes/durante el viaje) -->
          <% if ((t.tipo === 'viaje' || t.tipo === 'contenedor_entrega')) { %>
            <p class="mt-2 mb-1">
              <a href="/ventas/<%= t.id %>/remito" target="_blank" class="btn btn-sm btn-outline-secondary">
                <%- icon('receipt',{size:14}) %> Ver remito
              </a>
              <a href="/remitos/<%= t.id %>/pdf" target="_blank" class="btn btn-sm btn-outline-secondary ms-1">
                <%- icon('download',{size:14}) %> Descargar PDF
              </a>
            </p>
          <% } %>

          <div class="mt-2">
            <% if (t.fase === 'en_curso') { %>
              <% const requiereFirmado = (t.tipo === 'viaje' || t.tipo === 'contenedor_entrega') %>
              <form action="/hoja-de-ruta/<%= t.id %>/finalizar" method="POST"
                    enctype="multipart/form-data"
                    onsubmit="return confirm('¿Confirmás: <%= t.accionFinalizar %>?')">
                <% if (requiereFirmado) { %>
                  <div class="mb-2 remito-uploader" data-tarea="<%= t.id %>">
                    <label class="form-label fw-semibold mb-1">📷 Remito firmado *</label>
                    <input type="file" name="remito_firmado" accept="image/*,application/pdf" capture="environment"
                           class="form-control form-control-sm remito-input" required>
                    <small class="text-muted d-block mb-1">Sacá una foto del remito firmado o subí un archivo (PDF/JPG/PNG)</small>

                    <!-- Preview del archivo elegido -->
                    <div class="remito-preview" style="display:none; margin-top:0.5rem">
                      <div class="remito-preview__info text-muted small mb-1">
                        <span class="remito-preview__name fw-semibold"></span>
                        <span class="remito-preview__size"></span>
                      </div>
                      <img class="remito-preview__img" alt="Vista previa"
                           style="display:none; max-width:100%; max-height:240px; border-radius:8px; border:1px solid #e5e7eb">
                      <div class="remito-preview__pdf" style="display:none; padding:0.75rem; background:#f3f4f6; border-radius:8px; text-align:center">
                        📄 <span class="remito-preview__pdf-name"></span>
                      </div>
                      <button type="button" class="btn btn-sm btn-outline-secondary remito-preview__clear mt-1">
                        Cambiar archivo
                      </button>
                    </div>
                  </div>
                <% } %>

                <script>
                (function(){
                  document.querySelectorAll('.remito-uploader').forEach(function(wrap){
                    if (wrap.dataset.bound) return; wrap.dataset.bound = '1';
                    var input = wrap.querySelector('.remito-input');
                    var preview = wrap.querySelector('.remito-preview');
                    var img = wrap.querySelector('.remito-preview__img');
                    var pdf = wrap.querySelector('.remito-preview__pdf');
                    var pdfName = wrap.querySelector('.remito-preview__pdf-name');
                    var nameEl = wrap.querySelector('.remito-preview__name');
                    var sizeEl = wrap.querySelector('.remito-preview__size');
                    var clearBtn = wrap.querySelector('.remito-preview__clear');
                    var currentUrl = null;

                    function reset(){
                      if (currentUrl) { URL.revokeObjectURL(currentUrl); currentUrl = null; }
                      preview.style.display = 'none';
                      img.style.display = 'none'; img.src = '';
                      pdf.style.display = 'none'; pdfName.textContent = '';
                      input.value = '';
                    }

                    input.addEventListener('change', function(){
                      if (!input.files || !input.files[0]) { reset(); return; }
                      var f = input.files[0];
                      var kb = (f.size / 1024).toFixed(0);
                      var mb = (f.size / 1024 / 1024).toFixed(1);
                      var size = f.size > 1024 * 1024 ? (mb + ' MB') : (kb + ' KB');
                      nameEl.textContent = f.name;
                      sizeEl.textContent = ' · ' + size;
                      preview.style.display = 'block';

                      if (currentUrl) URL.revokeObjectURL(currentUrl);
                      currentUrl = URL.createObjectURL(f);

                      if (f.type.startsWith('image/')) {
                        img.src = currentUrl; img.style.display = 'block';
                        pdf.style.display = 'none';
                      } else if (f.type === 'application/pdf') {
                        pdfName.textContent = f.name;
                        pdf.style.display = 'block';
                        img.style.display = 'none';
                      }
                    });
                    clearBtn.addEventListener('click', reset);
                  });
                })();
                </script>
                <button class="btn btn-success"><%- icon('check',{size:15}) %> <%= t.accionFinalizar %></button>
              </form>
            <% } else if (t.bloqueada) { %>
              <button class="btn btn-outline-secondary" disabled title="Finalizá la tarea en curso primero"><%= t.accionIniciar %></button>
              <small class="text-muted ms-2">Bloqueada — hay una tarea en curso</small>
            <% } else { %>
              <form action="/hoja-de-ruta/<%= t.id %>/iniciar" method="POST" class="d-inline">
                <button class="btn btn-naranja" <%= t.sinContenedor ? 'disabled' : '' %>><%= t.accionIniciar %></button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>

  <!-- ── PRÓXIMOS VIAJES (planificados para otro día) ──────────── -->
  <% if (proximosList.length) { %>
    <h5 class="fw-bold mb-2 mt-4">🗓️ Próximos viajes</h5>
    <div class="d-flex flex-column gap-2 mb-3">
      <% proximosList.forEach(t => { %>
      <div class="card shadow-sm" style="opacity:0.92">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
              <span style="font-size:1.1rem"><%= t.icono %></span>
              <span class="fw-bold ms-1"><%= t.titulo %></span>
              <span class="badge rounded-pill px-3 badge-pendiente ms-2">Programado</span>
              <span class="text-muted ms-2">OP-<%= String(t.nro_op).padStart(4,'0') %></span>
            </div>
            <% if (t.fecha) { %>
              <small class="text-muted fw-semibold"><%- icon('clock',{size:13}) %> <%= formatFecha(t.fecha) %></small>
            <% } %>
          </div>

          <p class="fw-semibold mb-1 mt-2"><%= t.cliente %><% if (t.tel) { %> <small class="text-muted">· <%= t.tel %></small><% } %></p>
          <p class="mb-1">📍 <%= t.domicilio || 'Domicilio a coordinar' %></p>
          <% if (t.contenedor) { %><p class="text-muted small mb-1">Contenedor N° <%= t.contenedor %></p><% } %>
          <% if (t.camion) { %><p class="text-muted small mb-1">🚚 <%= t.camion %></p><% } %>
          <% if (t.observaciones) { %><p class="text-muted small mb-1"><%= t.observaciones %></p><% } %>

          <div class="mt-2 d-flex gap-2 flex-wrap">
            <form action="/hoja-de-ruta/<%= t.id %>/realizar-hoy" method="POST" class="d-inline"
                  onsubmit="return confirm('¿Reprogramar esta tarea para hoy? Va a quedar disponible para iniciarla ahora.')">
              <button class="btn btn-naranja btn-sm">📅 Realizar hoy</button>
            </form>
            <% if (t.tipo === 'viaje' || t.tipo === 'contenedor_entrega') { %>
              <a href="/ventas/<%= t.id %>/remito" target="_blank" class="btn btn-sm btn-outline-secondary">
                <%- icon('receipt',{size:14}) %> Ver remito
              </a>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Contenedores en alquiler (en domicilio, todavía no toca retirar) -->
  <% if (enServicio.length) { %>
    <div class="card shadow-sm">
      <div class="card-header bg-white fw-semibold">Contenedores en alquiler (en domicilio)</div>
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead><tr><th>OP</th><th>Cliente</th><th>Contenedor</th><th>Domicilio</th><th>Vence</th><th class="text-center">Días rest.</th></tr></thead>
          <tbody>
            <% enServicio.forEach(t => { %>
            <tr>
              <td class="fw-semibold">OP-<%= String(t.nro_op).padStart(4,'0') %></td>
              <td><%= t.cliente %></td>
              <td><%= t.contenedor ? 'N° '+t.contenedor : '—' %></td>
              <td><small class="text-muted"><%= t.domicilio || '—' %></small></td>
              <td><%= t.fin ? formatFecha(t.fin) : '—' %></td>
              <td class="text-center"><%= t.diasRestantes != null ? t.diasRestantes + 'd' : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

<% } %>
