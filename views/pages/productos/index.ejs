<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('box', { size: 18 }) %> Productos</h4>
  <a href="/productos/nuevo" class="btn btn-naranja">+ Nuevo Producto</a>
</div>

<%- include('../../partials/tabla_toolbar', {
  action: '/productos',
  placeholder: 'Buscar producto...',
  qValue: filtros.q,
  hiddenFilters: { sort: filtros.sort, dir: filtros.dir },
  filtros: [
    { name: 'estado', label: 'Estado', selected: filtros.estado, options: [
      { value: 'activo', label: 'Activos' },
      { value: 'inactivo', label: 'Inactivos' },
    ]},
  ],
}) %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!productos.length) { %>
      <%- include('../../partials/empty_state', { icono: '📦', mensaje: filtros.q ? 'No hay productos que coincidan.' : 'Aún no hay datos para mostrar.', accionHref: '/productos/nuevo', accionLabel: 'Crear primer producto' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <%- include('../../partials/th_sort', { sortKey: 'nombre', sortLabel: 'Nombre',            currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <%- include('../../partials/th_sort', { sortKey: 'unidad', sortLabel: 'Unidad',            currentSort: filtros.sort, currentDir: filtros.dir, filtros }) %>
          <%- include('../../partials/th_sort', { sortKey: 'precio', sortLabel: 'Precio Referencia', currentSort: filtros.sort, currentDir: filtros.dir, filtros, align: 'right' }) %>
          <th class="text-center">Estado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% productos.forEach(p => { %>
        <tr class="<%= !p.activo ? 'text-muted' : '' %>">
          <td class="fw-semibold"><%= p.nombre %></td>
          <td><small class="text-muted"><%= p.unidad_medida %></small></td>
          <td class="text-end fw-semibold text-orange">
            $<%= Number(p.precio_referencia || 0).toLocaleString('es-AR') %>
          </td>
          <td class="text-center">
            <% if (p.activo) { %>
              <span class="badge rounded-pill px-3 badge-activo">Activo</span>
            <% } else { %>
              <span class="badge rounded-pill px-3 badge-alerta">Inactivo</span>
            <% } %>
          </td>
          <td class="text-center">
            <a href="/productos/<%= p.id %>/editar" class="btn btn-sm btn-outline-secondary" title="Editar"><%- icon('edit', { size: 15 }) %></a>
            <form action="/productos/<%= p.id %>/toggle" method="POST" class="d-inline">
              <button class="btn btn-sm <%= p.activo ? 'btn-outline-danger' : 'btn-outline-success' %>"
                      title="<%= p.activo ? 'Desactivar' : 'Activar' %>">
                <%- p.activo ? icon('ban', { size: 15 }) : icon('check', { size: 15 }) %>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <%- include('../../partials/paginacion', { page, totalPaginas, total, limit, filtros }) %>
    <% } %>
  </div>
</div>
