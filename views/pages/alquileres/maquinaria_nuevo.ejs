<div class="page-header">
  <div>
    <a href="/alquileres/maquinaria" class="back-link">← Alquileres Maquinaria</a>
    <h1 class="page-title">Nuevo Alquiler de Maquinaria</h1>
  </div>
</div>

<script id="config-maquinaria" type="application/json"><%- JSON.stringify(configDefaults) %></script>

<form action="/alquileres/maquinaria" method="POST" class="alquiler-form-layout" id="formNuevoAlquilerMaq">

  <div class="alquiler-form-main">

    <!-- Cliente -->
    <div class="form-section">
      <%- include('../../partials/buscar_cliente') %>
    </div>

    <!-- Direccion -->
    <div class="form-section">
      <h3 class="form-section__title">Dirección de trabajo</h3>
      <div class="form-row-2">
        <div class="form-group">
          <label for="calle">Calle *</label>
          <input type="text" name="calle" id="calle" placeholder="Ej: Av. Colón" required>
        </div>
        <div class="form-group">
          <label for="numero">Número</label>
          <input type="text" name="numero" id="numero" placeholder="Ej: 1234">
        </div>
      </div>
      <div class="direccion-acciones">
        <div class="form-group">
          <label for="zona">Zona</label>
          <input type="text" name="zona_entrega" id="zona" placeholder="Ej: Norte">
        </div>
        <button type="button" id="btnBuscarDireccion" class="btn-secondary btn-buscar-mapa direccion-mapbtn"><%- icon('mapPin', { size: 15 }) %> Buscar en mapa</button>
      </div>
      <p id="msgMapa" class="form-hint" style="display:none">Ingresá calle y número para buscar.</p>
      <div id="mapaEntrega" style="display:none;margin-top:0.75rem">
        <div id="mapaMaquinaria" style="width:100%;height:250px;border-radius:8px"></div>
      </div>
    </div>

    <!-- Observaciones -->
    <div class="form-section">
      <h3 class="form-section__title">Observaciones</h3>
      <div class="form-group">
        <textarea name="observaciones" rows="3" placeholder="Notas adicionales..."></textarea>
      </div>
    </div>

  </div>

  <!-- Columna derecha -->
  <aside class="alquiler-form-aside">

    <!-- Maquinaria -->
    <div class="form-section">
      <h3 class="form-section__title">Maquinaria</h3>
      <div class="form-group">
        <label for="selectMaquinaria">Equipo a asignar</label>
        <select name="id_maquinaria" id="selectMaquinaria" class="form-select">
          <option value="">Sin asignar (asignar después)</option>
          <% disponibles.forEach(m => { %>
            <option value="<%= m.id %>"
                    data-precio-hora="<%= m.precio_por_hora || 0 %>"
                    data-precio-dia="<%= m.precio_por_dia || 0 %>"
                    data-modo="<%= m.modo_precio || 'hora' %>">
              <%= m.nombre %> (<%= m.tipo %>)
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Chofer -->
    <div class="form-section">
      <h3 class="form-section__title">Chofer (opcional)</h3>
      <div class="form-group">
        <select name="id_chofer" id="selectChofer" class="form-select">
          <option value="">Sin asignar</option>
          <% choferes.forEach(ch => { %>
            <option value="<%= ch.id %>"><%= ch.nombre %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Modalidad y precio -->
    <div class="form-section">
      <h3 class="form-section__title">Modalidad y precio</h3>
      <div class="form-group">
        <label>Tipo de alquiler</label>
        <div class="modalidad-group">
          <label class="modalidad-option">
            <input type="radio" name="modo_precio" value="hora" checked> Por horas
          </label>
          <label class="modalidad-option">
            <input type="radio" name="modo_precio" value="dia"> Por día
          </label>
        </div>
      </div>

      <div class="form-row-2">
        <div class="form-group" id="grupoHoras">
          <label for="horas_pactadas">Horas pactadas</label>
          <input type="number" name="horas_pactadas" id="horas_pactadas" step="0.5" min="0" value="0">
        </div>
        <div class="form-group" id="grupoDias">
          <label for="plazo_alquiler">Días estimados</label>
          <input type="number" name="plazo_alquiler" id="plazo_alquiler" min="1" value="1">
        </div>
      </div>

      <div class="form-group">
        <label for="precio_por_hora">Precio por hora ($)</label>
        <input type="number" name="precio_por_hora" id="precio_por_hora" step="1" min="0" value="0">
      </div>

      <div class="form-group">
        <label>Total calculado</label>
        <div id="precioTotalDisplay" class="resumen-valor fw-bold">$0</div>
        <input type="hidden" name="precio_total" id="precio_total" value="0">
      </div>
    </div>

    <!-- Metodo de pago -->
    <%- include('../../partials/metodo_pago') %>

    <!-- Resumen -->
    <div class="form-section alquiler-resumen">
      <h3 class="form-section__title">Resumen</h3>
      <div class="resumen-grid">
        <span class="resumen-label">Cliente</span>
        <span class="resumen-valor" id="res-cliente">—</span>
        <span class="resumen-label">Dirección</span>
        <span class="resumen-valor" id="res-direccion">—</span>
        <span class="resumen-label">Maquinaria</span>
        <span class="resumen-valor" id="res-maquinaria">—</span>
        <span class="resumen-label">Chofer</span>
        <span class="resumen-valor" id="res-chofer">—</span>
        <span class="resumen-label">Modalidad</span>
        <span class="resumen-valor" id="res-modalidad">—</span>
        <span class="resumen-label">Pago</span>
        <span class="resumen-valor" id="res-pago">—</span>
      </div>
      <div class="resumen-total">
        <span>Total</span>
        <span id="res-total-valor">$0</span>
      </div>
    </div>

    <button type="submit" class="btn-finalizar" id="btnConfirmarMaq">
      Confirmar alquiler
    </button>

  </aside>
</form>
