<%
  const estadoBadge = { borrador:'badge-pendiente', confirmado:'badge-en-transito', en_curso:'badge-en-transito', finalizado:'badge-activo' }
  const estadoLbl = { borrador:'Borrador', confirmado:'Confirmado', en_curso:'En curso', finalizado:'Finalizado' }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('map', { size: 18 }) %> Circuitos Logísticos</h4>
  <a href="/circuitos/nuevo" class="btn btn-naranja">+ Nuevo Circuito</a>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!circuitos.length) { %>
      <%- include('../../partials/empty_state', { icono: '🗺️', mensaje: 'No hay circuitos creados. Agrupá entregas y retiros en un circuito para organizar el día.', accionHref: '/circuitos/nuevo', accionLabel: 'Crear primer circuito' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead><tr><th>Fecha</th><th>Chofer</th><th>Camión</th><th class="text-center">Paradas</th><th class="text-center">Estado</th><th class="text-center">Acciones</th></tr></thead>
      <tbody>
        <% circuitos.forEach(c => { %>
        <tr>
          <td class="fw-semibold"><%= formatFecha(c.fecha) %></td>
          <td><%= c.chofer_nombre && c.chofer_nombre.trim() ? c.chofer_nombre : '— sin asignar —' %></td>
          <td><small class="text-muted"><%= [c.camion_nombre, c.camion_patente].filter(Boolean).join(' · ') || '—' %></small></td>
          <td class="text-center"><%= c.completadas %>/<%= c.paradas %></td>
          <td class="text-center"><span class="badge rounded-pill px-3 <%= estadoBadge[c.estado] %>"><%= estadoLbl[c.estado] %></span></td>
          <td class="text-center">
            <a href="/circuitos/<%= c.id %>" class="btn btn-sm btn-outline-secondary">Ver</a>
            <form action="/circuitos/<%= c.id %>/eliminar" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este circuito?')">
              <button class="btn btn-sm btn-outline-danger"><%- icon('trash',{size:14}) %></button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
