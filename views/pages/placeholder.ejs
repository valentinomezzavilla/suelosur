<div class="mb-4">
  <h4 class="fw-bold text-dark-title"><%= icono %> <%= titulo %></h4>
</div>

<div class="card shadow-sm placeholder-card">
  <div class="card-body text-center py-5">
    <div class="placeholder-icon"><%= icono %></div>
    <h5 class="mt-3 fw-bold text-dark-title">Módulo en desarrollo</h5>
    <p class="text-muted mb-1">Este módulo estará disponible próximamente.</p>
    <% if (typeof sprint !== 'undefined') { %>
      <span class="badge badge-sprint">
        Sprint <%= sprint %>
      </span>
    <% } %>
  </div>
</div>
