<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('truck', { size: 18 }) %> <%= titulo %></h4>
  <a href="/proveedores" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card shadow-sm maxw-600">
  <div class="card-body">
    <form action="<%= proveedor ? `/proveedores/${proveedor.id}?_method=PUT` : '/proveedores' %>" method="POST">
      <div class="mb-3">
        <label class="form-label">Razón social / Nombre comercial *</label>
        <input type="text" name="nombre" class="form-control" value="<%= proveedor?.nombre || '' %>" required autofocus>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">CUIT</label>
          <input type="text" name="cuit" class="form-control" value="<%= proveedor?.cuit || '' %>" placeholder="30-12345678-9">
        </div>
        <div class="col-md-6">
          <label class="form-label">Teléfono</label>
          <input type="text" name="telefono" class="form-control" value="<%= proveedor?.telefono || '' %>">
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" value="<%= proveedor?.email || '' %>">
      </div>
      <div class="mb-4">
        <label class="form-label">Domicilio</label>
        <input type="text" name="domicilio" class="form-control" value="<%= proveedor?.domicilio || '' %>">
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-naranja px-4"><%= proveedor ? 'Guardar cambios' : 'Crear proveedor' %></button>
        <a href="/proveedores" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
