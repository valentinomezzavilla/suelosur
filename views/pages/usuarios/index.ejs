<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('key', { size: 18 }) %> Usuarios</h4>
  <a href="/usuarios/nuevo" class="btn btn-naranja">+ Nuevo Usuario</a>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!usuarios.length) { %>
      <%- include('../../partials/empty_state', { icono: '🔑', mensaje: 'Aún no hay datos para mostrar.', accionHref: '/usuarios/nuevo', accionLabel: 'Crear primer usuario' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Usuario</th>
          <th>Rol</th>
          <th class="text-center">Estado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% usuarios.forEach(u => { %>
        <tr class="<%= !u.activo ? 'text-muted' : '' %>">
          <td class="fw-semibold"><%= u.nombre %></td>
          <td><code><%= u.usuario %></code></td>
          <td>
            <%
              const rolLabels = {
                dueno: '👑 Dueño',
                admin_ventas: '📋 Admin Ventas',
                admin_contable: '💰 Admin Contable',
                chofer: '🚛 Chofer'
              }
            %>
            <small><%= rolLabels[u.rol] || u.rol %></small>
          </td>
          <td class="text-center">
            <% if (u.activo) { %>
              <span class="badge rounded-pill px-3 badge-activo">Activo</span>
            <% } else { %>
              <span class="badge rounded-pill px-3 badge-alerta">Inactivo</span>
            <% } %>
          </td>
          <td class="text-center">
            <a href="/usuarios/<%= u.id %>/editar" class="btn btn-sm btn-outline-secondary" title="Editar"><%- icon('edit', { size: 15 }) %></a>
            <% if (u.id !== user.id) { %>
            <form action="/usuarios/<%= u.id %>/toggle" method="POST" class="d-inline">
              <button class="btn btn-sm <%= u.activo ? 'btn-outline-danger' : 'btn-outline-success' %>"
                      title="<%= u.activo ? 'Desactivar' : 'Activar' %>">
                <%- u.activo ? icon('ban', { size: 15 }) : icon('check', { size: 15 }) %>
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <%- include('../../partials/paginacion', { page, totalPaginas, total, limit, filtros }) %>
    <% } %>
  </div>
</div>
