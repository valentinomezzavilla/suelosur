<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('cart', { size: 18 }) %> Registrar Compra</h4>
  <a href="/compras" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card shadow-sm maxw-600">
  <div class="card-body">
    <form action="/compras" method="POST">
      <div class="mb-3">
        <label class="form-label">Producto *</label>
        <select name="id_producto" class="form-select" required>
          <option value="">Seleccionar...</option>
          <% productos.forEach(p => { %><option value="<%= p.id %>"><%= p.nombre %> (<%= p.unidad_medida %>)</option><% }) %>
        </select>
      </div>
      <div class="row g-3 mb-3">
        <div class="col-md-6"><label class="form-label">Cantidad *</label><input type="number" step="0.01" min="0.01" name="cantidad" class="form-control" required></div>
        <div class="col-md-6"><label class="form-label">Costo unitario</label><input type="number" step="0.01" min="0" name="costo_unitario" class="form-control" placeholder="0"></div>
      </div>
      <div class="mb-3">
        <label class="form-label">Proveedor</label>
        <input type="text" id="buscarProv" class="form-control form-control-sm mb-1" placeholder="Buscar por razón social o CUIT...">
        <select name="id_proveedor" id="selProv" class="form-select">
          <option value="">— Sin proveedor —</option>
          <% proveedores.forEach(p => { %><option value="<%= p.id %>" data-search="<%= (p.nombre + ' ' + (p.cuit||'')).toLowerCase() %>"><%= p.nombre %><%= p.cuit ? ' (' + p.cuit + ')' : '' %></option><% }) %>
        </select>
      </div>
      <div class="mb-4">
        <label class="form-label">Observaciones</label>
        <input type="text" name="observaciones" class="form-control" placeholder="N° de remito del proveedor, notas...">
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-naranja px-4">Registrar compra</button>
        <a href="/compras" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const b = document.getElementById('buscarProv'), s = document.getElementById('selProv')
    if (!b || !s) return
    b.addEventListener('input', () => {
      const q = b.value.trim().toLowerCase(); let first = ''
      Array.from(s.options).forEach(o => { if (!o.value) return; const hay = (o.dataset.search||'').includes(q); o.hidden = q && !hay; if (hay && !first) first = o.value })
      if (q && first) s.value = first
    })
  })()
</script>
