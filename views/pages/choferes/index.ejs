<%
  const diasHasta = (f) => { if(!f) return null; const s=String(f).slice(0,10); const m=s.match(/^(\d{4})-(\d{2})-(\d{2})$/); if(!m) return null; const d=new Date(+m[1],+m[2]-1,+m[3]); const h=new Date(); return Math.round((d-new Date(h.getFullYear(),h.getMonth(),h.getDate()))/86400000) }
  const licBadge = (f) => { const d=diasHasta(f); if(d==null) return ['badge-pendiente','—']; if(d<0) return ['badge-alerta','Vencida']; if(d<=30) return ['badge-alerta', d+'d']; if(d<=90) return ['badge-en-transito', d+'d']; return ['badge-activo', formatFecha(f)] }
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('hardhat', { size: 18 }) %> Choferes</h4>
  <div class="d-flex gap-2">
    <a href="/choferes/dashboard" class="btn btn-sm btn-outline-secondary"><%- icon('chart', { size: 15 }) %> Dashboard</a>
    <div class="dropdown d-inline">
      <a href="/choferes/reporte/licencias" class="btn btn-sm btn-outline-secondary"><%- icon('printer', { size: 15 }) %> Reportes</a>
    </div>
    <a href="/choferes/nuevo" class="btn btn-naranja">+ Nuevo Chofer</a>
  </div>
</div>

<form method="GET" action="/choferes" class="card shadow-sm mb-3">
  <div class="card-body py-2">
    <div class="row g-2 align-items-end">
      <div class="col-md-6">
        <label class="form-label">Buscar</label>
        <input type="text" name="q" value="<%= filtros.q || '' %>" class="form-control form-control-sm"
               placeholder="Legajo, apellido, nombre o DNI..." autofocus>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-naranja">Buscar</button>
        <% if (filtros.q) { %><a href="/choferes" class="btn btn-sm btn-outline-secondary ms-1">Limpiar</a><% } %>
      </div>
    </div>
  </div>
</form>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!choferes.length) { %>
      <%- include('../../partials/empty_state', { icono: '👷', mensaje: 'No hay choferes registrados.', accionHref: '/choferes/nuevo', accionLabel: 'Crear primer chofer' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th class="col-w-50">Legajo</th>
          <th>Chofer</th>
          <th>DNI</th>
          <th>Licencia</th>
          <th>Camión asignado</th>
          <th class="text-center">Estado</th>
          <th class="text-center">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% choferes.forEach(c => { const lb = licBadge(c.licencia_vencimiento) %>
        <tr class="<%= !c.activo ? 'text-muted' : '' %>">
          <td class="fw-semibold text-orange">#<%= c.legajo %></td>
          <td class="fw-semibold"><%= c.nombre %> <%= c.apellido %></td>
          <td><small class="text-muted"><%= c.dni || '—' %></small></td>
          <td><span class="badge rounded-pill px-3 <%= lb[0] %>"><%= lb[1] %></span></td>
          <td><small class="text-muted"><%= c.camion_principal || '— sin asignar —' %></small></td>
          <td class="text-center">
            <% if (c.activo) { %><span class="badge rounded-pill px-3 badge-activo">Activo</span>
            <% } else { %><span class="badge rounded-pill px-3 badge-alerta">Baja</span><% } %>
          </td>
          <td class="text-center">
            <a href="/choferes/<%= c.id %>" class="btn btn-sm btn-outline-secondary" title="Ver"><%- icon('eye', { size: 15 }) %></a>
            <a href="/choferes/<%= c.id %>/editar" class="btn btn-sm btn-outline-secondary" title="Editar"><%- icon('edit', { size: 15 }) %></a>
            <button type="button" class="btn btn-sm btn-outline-secondary" title="Ver ubicación" onclick="verEnMapa('<%= c.id %>', '<%= c.nombre %> <%= c.apellido %>')"><%- icon('map', { size: 15 }) %></button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<!-- Modal para ver chofer en mapa -->
<div class="modal fade" id="mapModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="mapModalTitle">Ubicación del chofer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="height: 400px; padding: 0;">
        <div id="choferMap" style="width: 100%; height: 100%;"></div>
      </div>
      <div class="modal-footer">
        <div id="mapStatus" class="text-muted small" style="flex: 1; text-align: left;"></div>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
let choferMapInstance;
let choferMarker;

// Formatear fecha de manera amigable
function formatearUbicacion(fechaStr) {
  // La fecha viene del servidor en formato UTC
  // JavaScript convierte automáticamente a la zona horaria local
  const fecha = new Date(fechaStr);
  const ahora = new Date();

  // Diferenciar en milisegundos
  const diff = ahora - fecha;
  const minutos = Math.floor(diff / (1000 * 60));
  const horas = Math.floor(diff / (1000 * 60 * 60));
  const dias = Math.floor(diff / (1000 * 60 * 60 * 24));

  // Asegurarse de que los valores son positivos
  const minutosAbs = Math.abs(minutos);
  const horasAbs = Math.abs(horas);
  const diasAbs = Math.abs(dias);

  // Formatear hora (16:30) - usar la zona horaria local del navegador
  const horas24 = String(fecha.getHours()).padStart(2, '0');
  const mins = String(fecha.getMinutes()).padStart(2, '0');
  const hora = `${horas24}:${mins}`;

  // Determinar si es hoy, ayer, etc
  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);
  const ayer = new Date(hoy);
  ayer.setDate(ayer.getDate() - 1);
  const fechaObj = new Date(fechaStr);
  fechaObj.setHours(0, 0, 0, 0);

  let cuando;
  if (fechaObj.getTime() === hoy.getTime()) {
    cuando = 'hoy';
  } else if (fechaObj.getTime() === ayer.getTime()) {
    cuando = 'ayer';
  } else {
    // Formato: "26 de junio"
    const opciones = { day: 'numeric', month: 'long' };
    cuando = new Intl.DateTimeFormat('es-AR', opciones).format(fecha);
  }

  // Tiempo relativo
  let relativo;
  if (minutosAbs < 1) {
    relativo = 'justo ahora';
  } else if (minutosAbs < 60) {
    relativo = `hace ${minutosAbs} ${minutosAbs === 1 ? 'minuto' : 'minutos'}`;
  } else if (horasAbs < 24) {
    relativo = `hace ${horasAbs} ${horasAbs === 1 ? 'hora' : 'horas'}`;
  } else if (diasAbs < 7) {
    relativo = `hace ${diasAbs} ${diasAbs === 1 ? 'día' : 'días'}`;
  } else {
    relativo = 'hace mucho tiempo';
  }

  return `📍 Última vez ${cuando} a las ${hora} (${relativo})`;
}

async function verEnMapa(choferId, choferNombre) {
  document.getElementById('mapModalTitle').textContent = `Ubicación: ${choferNombre}`;

  const modal = new bootstrap.Modal(document.getElementById('mapModal'));
  modal.show();

  // Esperar a que el modal se muestre para inicializar el mapa
  setTimeout(() => {
    if (!choferMapInstance) {
      choferMapInstance = L.map('choferMap').setView([-31.4, -64.2], 13);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 19
      }).addTo(choferMapInstance);

      choferMarker = L.circleMarker([0, 0], {
        radius: 10,
        fillColor: '#3b82f6',
        color: '#fff',
        weight: 2,
        opacity: 1,
        fillOpacity: 0.8
      }).addTo(choferMapInstance);
    }

    // Obtener ubicación actual del chofer
    obtenerYMostrarUbicacion(choferId);
  }, 200);
}

async function obtenerYMostrarUbicacion(choferId) {
  try {
    const res = await fetch(`/choferes/${choferId}/ubicacion-actual`);
    const data = await res.json();

    const mapStatus = document.getElementById('mapStatus');

    if (data.lat && data.lng) {
      choferMarker.setLatLng([data.lat, data.lng]);
      choferMapInstance.panTo([data.lat, data.lng]);
      mapStatus.textContent = formatearUbicacion(data.fecha);
      mapStatus.style.color = '#333';
    } else {
      mapStatus.textContent = '📍 Sin rastreo disponible para este chofer';
      mapStatus.style.color = '#dc2626';
    }
  } catch (err) {
    console.error(err);
    document.getElementById('mapStatus').textContent = '⚠️ Error al cargar ubicación';
    document.getElementById('mapStatus').style.color = '#dc2626';
  }
}
</script>
