<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('layers', { size: 18 }) %> Stock de Áridos</h4>
  <button class="btn btn-naranja" data-bs-toggle="modal" data-bs-target="#modalIngreso">
    + Registrar Ingreso
  </button>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <% if (!stock.length) { %>
      <%- include('../../partials/empty_state', { icono: '🏗️', mensaje: 'Aún no hay datos para mostrar.', accionHref: '/productos/nuevo', accionLabel: 'Crear primer producto' }) %>
    <% } else { %>
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Producto</th>
          <th>Unidad</th>
          <th class="text-end">Stock Actual</th>
          <th class="text-end">Pend. Entrega</th>
          <th class="text-end">Disponible Real</th>
          <th class="text-end">Stock Mínimo</th>
          <th class="text-center">Estado</th>
          <th class="text-center">Ajustar</th>
        </tr>
      </thead>
      <tbody>
        <% stock.forEach(item => {
             let estadoClass, estadoLabel
             if (item.disponible_real <= 0) {
               estadoClass = 'badge-alerta'; estadoLabel = 'Sin stock'
             } else if (item.disponible_real < item.stock_minimo) {
               estadoClass = 'badge-pendiente'; estadoLabel = 'Bajo mínimo'
             } else {
               estadoClass = 'badge-activo'; estadoLabel = 'OK'
             }
        %>
        <tr>
          <td class="fw-semibold"><%= item.nombre %></td>
          <td class="text-muted"><%= item.unidad_medida %></td>
          <td class="text-end"><%= item.cantidad_actual.toFixed(2) %></td>
          <td class="text-end text-warning fw-semibold"><%= item.cant_pendiente_entregar.toFixed(2) %></td>
          <td class="text-end fw-bold text-orange"><%= item.disponible_real.toFixed(2) %></td>
          <td class="text-end text-muted"><%= item.stock_minimo.toFixed(2) %></td>
          <td class="text-center">
            <span class="badge rounded-pill px-3 py-1 <%= estadoClass %>"><%= estadoLabel %></span>
          </td>
          <td class="text-center">
            <button class="btn btn-sm btn-outline-secondary me-1"
                    data-bs-toggle="modal"
                    data-bs-target="#modalAjuste"
                    data-id="<%= item.id %>"
                    data-nombre="<%= item.nombre %>"
                    data-actual="<%= item.cantidad_actual %>"
                    data-minimo="<%= item.stock_minimo %>">
              <%- icon('edit', { size: 14 }) %> Ajustar
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<!-- Modal ajuste de stock -->
<div class="modal fade" id="modalAjuste" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form id="formAjuste" method="POST">
        <div class="modal-header modal-header-dark">
          <h6 class="modal-title text-white fw-bold">Ajustar Stock</h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="fw-semibold mb-3" id="modalProductoNombre"></p>
          <div class="mb-3">
            <label class="form-label">Stock Actual</label>
            <input type="number" name="cantidad_actual" id="inputActual"
                   class="form-control" step="1" min="0" required>
          </div>
          <div class="mb-1">
            <label class="form-label">Stock Mínimo</label>
            <input type="number" name="stock_minimo" id="inputMinimo"
                   class="form-control" step="1" min="0" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-sm btn-naranja">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal ingreso de stock -->
<div class="modal fade" id="modalIngreso" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form id="formIngreso" method="POST">
        <div class="modal-header modal-header-dark">
          <h6 class="modal-title text-white fw-bold">Registrar Ingreso</h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Producto</label>
            <select id="selectProductoIngreso" class="form-select" required>
              <option value="">Seleccionar...</option>
              <% stock.forEach(item => { %>
                <option value="<%= item.id %>" data-unidad="<%= item.unidad_medida %>">
                  <%= item.nombre %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Cantidad a ingresar</label>
            <div class="input-group">
              <input type="number" name="cantidad" id="inputCantidadIngreso"
                     class="form-control" step="1" min="1" required placeholder="0">
              <span class="input-group-text" id="unidadIngreso">—</span>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Proveedor</label>
            <input type="text" id="buscarProveedor" class="form-control form-control-sm mb-1"
                   placeholder="Buscar por razón social o CUIT...">
            <select name="id_proveedor" id="selectProveedorIngreso" class="form-select">
              <option value="">— Sin proveedor —</option>
              <% (proveedores || []).forEach(p => { %>
                <option value="<%= p.id %>" data-search="<%= (p.nombre + ' ' + (p.cuit||'')).toLowerCase() %>">
                  <%= p.nombre %><%= p.cuit ? ' (' + p.cuit + ')' : '' %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-1">
            <label class="form-label">Costo unitario (opcional)</label>
            <input type="number" name="costo_unitario" class="form-control" step="0.01" min="0" placeholder="0">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-sm btn-naranja">Registrar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Filtro inteligente del selector de proveedor (por razón social / CUIT)
  (function () {
    const buscar = document.getElementById('buscarProveedor')
    const select = document.getElementById('selectProveedorIngreso')
    if (!buscar || !select) return
    buscar.addEventListener('input', () => {
      const q = buscar.value.trim().toLowerCase()
      let firstMatch = ''
      Array.from(select.options).forEach(opt => {
        if (!opt.value) return
        const hay = (opt.dataset.search || '').includes(q)
        opt.hidden = q && !hay
        if (hay && !firstMatch) firstMatch = opt.value
      })
      if (q && firstMatch) select.value = firstMatch
    })
  })()
</script>

