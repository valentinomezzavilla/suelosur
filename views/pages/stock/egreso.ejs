<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0 text-dark-title"><%- icon('layers', { size: 18 }) %> Stock — Egreso Manual</h4>
  <a href="/stock" class="btn btn-sm btn-outline-secondary">← Ver niveles de stock</a>
</div>

<div class="row g-3">

  <!-- Formulario -->
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-header card-header-orange">Registrar egreso</div>
      <div class="card-body">
        <form id="formEgreso" method="POST" action="#">
          <div class="mb-3">
            <label class="form-label">Producto *</label>
            <select id="selectProducto" class="form-select" required>
              <option value="">Seleccionar producto...</option>
              <% stock.forEach(item => { %>
                <option value="<%= item.id %>"
                        data-unidad="<%= item.unidad_medida %>"
                        data-actual="<%= item.cantidad_actual.toFixed(2) %>">
                  <%= item.nombre %> (disponible: <%= item.disponible_real.toFixed(2) %> <%= item.unidad_medida %>)
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Cantidad a retirar *</label>
            <div class="input-group">
              <input type="number" name="cantidad" id="inputCantidad"
                     class="form-control" step="1" min="0.01" required placeholder="0.00">
              <span class="input-group-text" id="labelUnidad">—</span>
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label">Motivo</label>
            <select name="motivo" class="form-select">
              <option value="">Sin especificar</option>
              <option value="Merma / pérdida">Merma / pérdida</option>
              <option value="Uso interno">Uso interno</option>
              <option value="Ajuste de inventario">Ajuste de inventario</option>
              <option value="Devolución a proveedor">Devolución a proveedor</option>
              <option value="Otro">Otro</option>
            </select>
          </div>
          <button type="submit" class="btn btn-naranja w-100">Registrar egreso</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Tabla de niveles actuales -->
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-header card-header-light">Niveles actuales de stock</div>
      <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Producto</th>
              <th class="text-end">Stock actual</th>
              <th class="text-end">Disponible</th>
              <th>Unidad</th>
            </tr>
          </thead>
          <tbody>
            <% stock.forEach(item => { %>
            <tr>
              <td class="fw-semibold"><%= item.nombre %></td>
              <td class="text-end"><%= item.cantidad_actual.toFixed(2) %></td>
              <td class="text-end fw-bold text-orange"><%= item.disponible_real.toFixed(2) %></td>
              <td class="text-muted"><%= item.unidad_medida %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

