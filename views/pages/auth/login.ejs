<div class="login-card">

  <div class="login-logo-wrap">
    <img src="/img/suelosurjpg.jpg" class="login-logo" alt="Suelosur">
  </div>

  <h1 class="login-title">Suelo Sur SAS</h1>
  <p class="login-subtitle">Sistema Gestión Empresarial</p>
  <p class="login-desc">Áridos, contenedores y <span class="login-desc-accent">movimientos de suelo</span></p>

  <% if (error && error.length > 0) { %>
    <div class="alert alert-danger py-2 small mb-3 text-start">❌ <%= error[0] %></div>
  <% } %>

  <form action="/auth/login" method="POST" class="login-form" id="loginForm" data-loading-text="Ingresando…">
    <div class="login-field">
      <label class="login-label" for="inputUsuario">Usuario</label>
      <input
        id="inputUsuario"
        type="text"
        name="usuario"
        class="login-input"
        required
        autofocus
        autocomplete="username"
      >
    </div>

    <div class="login-field">
      <label class="login-label" for="inputPassword">Contraseña</label>
      <div class="login-pwd-wrap">
        <input
          id="inputPassword"
          type="password"
          name="password"
          class="login-input"
          placeholder="••••••••"
          required
          autocomplete="current-password"
        >
        <button type="button" class="login-eye" id="togglePwd" aria-label="Mostrar contraseña">
          <svg id="eyeIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </button>
      </div>
    </div>

    <button type="submit" class="login-submit">Ingresar</button>
  </form>

  <p class="login-footer">
    ¿Problemas para acceder?
    <a href="mailto:admin@suelosur.com" class="login-footer-link">Contactá al administrador.</a>
  </p>

</div>

<script>
  (function () {
    var btn = document.getElementById('togglePwd');
    var inp = document.getElementById('inputPassword');
    var eyeOpen  = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
    var eyeClosed = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
    btn.addEventListener('click', function () {
      var shown = inp.type === 'text';
      inp.type = shown ? 'password' : 'text';
      document.getElementById('eyeIcon').innerHTML = shown ? eyeOpen : eyeClosed;
    });
    // El loader al enviar lo maneja /js/appLoader.js (data-loading-text del form)
  })();
</script>
