<main id="transacciones-page">

            <%
                const tipoCorto = { 'Venta Cantera':'Cantera', 'Venta Viaje':'Viaje', 'Alquiler':'Contenedor', 'Maquinaria':'Máquina', 'Ajuste':'Ajuste' }
                const m = metricas || { total:0, count:0, ventas:0, alquileres:0 }
                const money = (n) => '$' + Number(n||0).toLocaleString('es-AR')
                const presetHref = (p) => {
                    const o = { preset: p }
                    if (filtros.tipo && filtros.tipo !== 'todos') o.tipo = filtros.tipo
                    if (filtros.cliente) o.cliente = filtros.cliente
                    return '/transacciones?' + new URLSearchParams(o).toString()
                }
            %>

            <div class="page-header">
                <h1 class="page-title"><%- icon('receipt', { size: 18 }) %> Transacciones</h1>
            </div>

            <!-- Métricas del período -->
            <div class="stat-cards">
                <div class="stat-card stat-card--neutral">
                    <div class="stat-card__icon"><%- icon('chart', { size: 20 }) %></div>
                    <div class="stat-card__body"><span class="stat-card__value"><%= money(m.total) %></span><span class="stat-card__label">Total · <%= periodoLabel %></span></div>
                </div>
                <div class="stat-card stat-card--info">
                    <div class="stat-card__icon"><%- icon('clipboard', { size: 20 }) %></div>
                    <div class="stat-card__body"><span class="stat-card__value"><%= m.count %></span><span class="stat-card__label">Operaciones</span></div>
                </div>
                <div class="stat-card stat-card--success">
                    <div class="stat-card__icon"><%- icon('box', { size: 20 }) %></div>
                    <div class="stat-card__body"><span class="stat-card__value"><%= money(m.ventas) %></span><span class="stat-card__label">Ventas</span></div>
                </div>
                <div class="stat-card stat-card--warning">
                    <div class="stat-card__icon"><%- icon('truck', { size: 20 }) %></div>
                    <div class="stat-card__body"><span class="stat-card__value"><%= money(m.alquileres) %></span><span class="stat-card__label">Alquileres</span></div>
                </div>
            </div>

            <!-- Presets de período -->
            <div class="periodo-chips">
                <a href="<%= presetHref('hoy') %>"    class="periodo-chip <%= filtros.preset==='hoy'    ? 'is-active' : '' %>">Hoy</a>
                <a href="<%= presetHref('semana') %>" class="periodo-chip <%= filtros.preset==='semana' ? 'is-active' : '' %>">Esta semana</a>
                <a href="<%= presetHref('mes') %>"    class="periodo-chip <%= filtros.preset==='mes'    ? 'is-active' : '' %>">Este mes</a>
            </div>

            <!-- Filtros -->
            <form method="GET" action="/transacciones" class="filtros-bar filtros-bar--extended">
                <input type="hidden" name="preset" value="rango">
                <div class="filtro-group">
                    <label>Tipo</label>
                    <select name="tipo">
                        <option value="todos" <%=filtros.tipo==='todos' || !filtros.tipo ? 'selected' : '' %>>Todos
                        </option>
                        <% tipos.forEach(t=> { %>
                            <option value="<%= t %>" <%=filtros.tipo===t ? 'selected' : '' %>><%= t %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="filtro-group">
                    <label>Cliente</label>
                    <input type="text" name="cliente" value="<%= filtros.cliente %>" list="listaClientesTx"
                        placeholder="Buscar por nombre / apellido / DNI..." autocomplete="off">
                    <datalist id="listaClientesTx">
                        <% (clientesLista || []).forEach(c => { %>
                            <option value="<%= c.nombre %> <%= c.apellido || '' %>"><%= c.dni ? 'DNI ' + c.dni : '' %> <%= c.numero ? '· #' + c.numero : '' %></option>
                        <% }) %>
                    </datalist>
                </div>
                <div class="filtro-group">
                    <label>Desde</label>
                    <input type="date" name="fechaDesde" value="<%= filtros.fechaDesde %>">
                </div>
                <div class="filtro-group">
                    <label>Hasta</label>
                    <input type="date" name="fechaHasta" value="<%= filtros.fechaHasta %>">
                </div>
                <div class="filtro-group">
                    <label>Monto mín.</label>
                    <input type="number" name="montoMin" value="<%= filtros.montoMin %>" placeholder="0" min="0">
                </div>
                <div class="filtro-group">
                    <label>Monto máx.</label>
                    <input type="number" name="montoMax" value="<%= filtros.montoMax %>" placeholder="Sin límite"
                        min="0">
                </div>
                <button type="submit" class="btn-primary">Filtrar</button>
                <a href="/transacciones" class="btn-secondary">Limpiar</a>
            </form>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Tipo</th>
                            <th>Cliente</th>
                            <th>Descripción</th>
                            <th>Fecha</th>
                            <th>Monto</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transacciones.length===0) { %>
                            <tr>
                                <td colspan="7" class="td-vacia">No hay transacciones que coincidan con los filtros</td>
                            </tr>
                            <% } %>
                                <% transacciones.forEach(t=> { %>
                                    <tr>
                                        <td class="fw-semibold text-orange"><%= codigoTx(t) %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge badge--tipo-<%= t.tipo.toLowerCase().replace(/ /g,'-') %>">
                                                <%= tipoCorto[t.tipo] || t.tipo %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= t.cliente %>
                                        </td>
                                        <td>
                                            <%= t.descripcion %>
                                        </td>
                                        <td>
                                            <%= formatFecha(t.fecha) %>
                                        </td>
                                        <td class="transaccion-monto">$<%= t.monto?.toLocaleString('es-AR') %>
                                        </td>
                                        <td>
                                            <button type="button" class="btn-secondary btn-sm btn-ver-transaccion"
                                                data-id="<%= codigoTx(t) %>" data-tipo="<%= t.tipo %>"
                                                data-cliente="<%= t.cliente %>" data-descripcion="<%= t.descripcion %>"
                                                data-fecha="<%= formatFecha(t.fecha) %>" data-monto="<%= t.monto %>"
                                                data-metodo-pago="<%= t.metodoPago || '' %>">
                                                Ver
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (totalPaginas > 1) { %>
                <%
                    const qs = Object.entries(filtros).filter(([, v]) => v !== '' && v != null).map(([k, v]) => `${k}=${encodeURIComponent(v)}`).join('&');
                    const base = '/transacciones?' + (qs ? qs + '&' : '');
                %>
                <nav class="pagination" style="display:flex;justify-content:center;align-items:center;gap:0.75rem;padding:1rem 0;margin-top:0.5rem">
                    <% if (pagina > 1) { %>
                        <a href="<%= base %>page=<%= pagina - 1 %>" class="btn-secondary btn-sm">← Anterior</a>
                    <% } else { %>
                        <span class="btn-secondary btn-sm" style="opacity:0.4;pointer-events:none">← Anterior</span>
                    <% } %>
                    <span style="font-weight:600">Página <%= pagina %> de <%= totalPaginas %> (<%= totalTransacciones %> resultados)</span>
                    <% if (pagina < totalPaginas) { %>
                        <a href="<%= base %>page=<%= pagina + 1 %>" class="btn-secondary btn-sm">Siguiente →</a>
                    <% } else { %>
                        <span class="btn-secondary btn-sm" style="opacity:0.4;pointer-events:none">Siguiente →</span>
                    <% } %>
                </nav>
            <% } %>

        </main>

        <!-- Modal detalle transaccion -->
        <div id="modal-transaccion" class="modal-overlay" style="display:none">
            <div class="modal-box">
                <div class="modal-header">
                    <h2 class="modal-title">Detalle de transacción <span id="modal-t-id"></span></h2>
                    <button type="button" class="modal-close" id="cerrarModalTransaccion">✕</button>
                </div>
                <div class="alquiler-resumen__rows" style="margin-top:1rem">
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Tipo</span>
                        <span id="modal-t-tipo"></span>
                    </div>
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Cliente</span>
                        <span id="modal-t-cliente"></span>
                    </div>
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Descripción</span>
                        <span id="modal-t-descripcion"></span>
                    </div>
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Fecha</span>
                        <span id="modal-t-fecha"></span>
                    </div>
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Monto</span>
                        <span id="modal-t-monto" style="font-weight:700"></span>
                    </div>
                    <div class="alquiler-resumen__row">
                        <span class="alquiler-resumen__label">Método de pago</span>
                        <span id="modal-t-metodo-pago" style="font-weight:700"></span>
                    </div>
                </div>
                <div class="modal-actions" style="margin-top:1.5rem">
                    <button type="button" class="btn-secondary" id="cerrarModalTransaccionBtn">Cerrar</button>
                </div>
            </div>
        </div>
