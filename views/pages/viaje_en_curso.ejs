<%
  // viaje_en_curso.ejs — Navegación del chofer en tiempo real (estilo GPS).
  // El destino llega ya geocodificado desde el backend (op.domicilio_lat/lng).
%>

<style>
  .nav-wrapper {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    background: #e8eaed; z-index: 1000;
    overflow: hidden;
  }

  .nav-map-container { position: relative; flex: 1 1 auto; min-height: 0; }
  #map { position: absolute; inset: 0; width: 100%; height: 100%; background: #e8eaed; }

  /* ── Header flotante ── */
  .nav-top {
    position: absolute; top: 12px; left: 12px; right: 12px;
    display: flex; gap: 0.6rem; align-items: stretch; z-index: 600;
    pointer-events: none;
  }
  .nav-top > * { pointer-events: auto; }
  .nav-icon-btn {
    width: 44px; height: 44px; flex-shrink: 0;
    border-radius: 50%; background: #fff; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 6px rgba(0,0,0,.25); font-size: 20px; color: #333;
  }
  .nav-icon-btn:active { background: #f0f0f0; }
  .nav-dest-chip {
    flex: 1; min-width: 0; background: #fff; border-radius: 10px;
    padding: 0.5rem 0.85rem; box-shadow: 0 2px 6px rgba(0,0,0,.2);
    display: flex; flex-direction: column; justify-content: center;
  }
  .nav-dest-chip .d {
    font-weight: 600; color: #202124; font-size: 0.9rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .nav-dest-chip .c {
    color: #5f6368; font-size: 0.78rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ── Botones flotantes (FAB) ── */
  .nav-fabs {
    position: absolute; right: 14px; z-index: 600;
    bottom: 16px; display: flex; flex-direction: column; gap: 10px;
    transition: bottom .28s ease;
  }
  .nav-fab {
    width: 48px; height: 48px; border-radius: 50%;
    background: #fff; border: none; cursor: pointer;
    box-shadow: 0 3px 8px rgba(0,0,0,.28);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; color: #1a73e8;
  }
  .nav-fab:active { background: #f0f0f0; }
  .nav-fab[hidden] { display: none; }
  .nav-fab--info { color: #333; font-size: 14px; font-weight: 600; width: auto; padding: 0 16px; border-radius: 24px; gap: 6px; }

  /* ── Marcador del chofer (puck con flecha de dirección) ── */
  .nav-puck { position: relative; width: 34px; height: 34px; }
  .nav-puck__dot {
    position: absolute; inset: 6px; border-radius: 50%;
    background: #1a73e8; border: 3px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,.4);
  }
  .nav-puck__arrow {
    position: absolute; top: -4px; left: 50%;
    width: 0; height: 0;
    border-left: 7px solid transparent; border-right: 7px solid transparent;
    border-bottom: 11px solid #1a73e8;
    transform-origin: 50% 21px; transform: translateX(-50%) rotate(0deg);
    transition: transform .3s linear;
    filter: drop-shadow(0 1px 1px rgba(0,0,0,.3));
  }
  .leaflet-marker-icon.nav-puck-icon { transition: transform .8s linear; }

  /* ── Panel inferior (bottom sheet) ── */
  .nav-panel {
    flex-shrink: 0; background: #fff;
    border-radius: 18px 18px 0 0;
    box-shadow: 0 -2px 16px rgba(0,0,0,.12);
    display: flex; flex-direction: column;
    transition: max-height .28s ease, transform .28s ease;
    max-height: 60vh; overflow: hidden;
  }
  .nav-panel.collapsed { max-height: 116px; }
  .nav-panel.hidden { transform: translateY(100%); max-height: 0; }

  .nav-grip { padding: 8px 0 4px; display: flex; justify-content: center; cursor: pointer; flex-shrink: 0; }
  .nav-grip span { width: 40px; height: 5px; border-radius: 3px; background: #dadce0; }

  .nav-stats {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0 1rem 0.6rem; flex-shrink: 0;
  }
  .nav-stat { flex: 1; text-align: center; }
  .nav-stat b { display: block; font-size: 1.35rem; font-weight: 700; color: #202124; line-height: 1.1; }
  .nav-stat span { font-size: 0.72rem; color: #80868b; font-weight: 500; }
  .nav-stat--primary b { color: #1a73e8; }
  .nav-panel-hide {
    border: none; background: #f1f3f4; color: #5f6368; cursor: pointer;
    width: 36px; height: 36px; border-radius: 50%; font-size: 16px; flex-shrink: 0;
  }
  .nav-panel-hide:active { background: #e0e0e0; }

  .nav-body { overflow-y: auto; padding: 0.25rem 1rem 1rem; }

  .nav-dest-card {
    background: #f8f9fa; padding: 0.85rem; border-radius: 12px;
    margin-bottom: 0.85rem; display: flex; gap: 0.85rem; align-items: flex-start;
  }
  .nav-dest-card__icon {
    width: 38px; height: 38px; border-radius: 50%; flex-shrink: 0;
    background: #1a73e8; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18px;
  }
  .nav-dest-card__info h4 { margin: 0 0 2px; font-size: 0.95rem; font-weight: 600; color: #202124; }
  .nav-dest-card__info p { margin: 0; font-size: 0.85rem; color: #5f6368; }

  .nav-status {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.6rem 0.85rem; border-radius: 10px; font-size: 0.85rem;
    background: #e8f0fe; color: #1967d2; margin-bottom: 0.85rem;
  }
  .nav-status.active { background: #e6f4ea; color: #188038; }
  .nav-status.error  { background: #fce8e6; color: #c5221f; }
  .nav-status .spinner {
    width: 0.7rem; height: 0.7rem; border: 2px solid rgba(0,0,0,.15);
    border-top-color: currentColor; border-radius: 50%;
    animation: navspin .8s linear infinite; flex-shrink: 0;
  }
  .nav-status.active .spinner, .nav-status.error .spinner { display: none; }
  .nav-status__retry {
    margin-left: auto; border: 1px solid currentColor; background: transparent;
    color: inherit; border-radius: 6px; padding: 2px 10px; font-size: 0.78rem; cursor: pointer;
  }
  @keyframes navspin { to { transform: rotate(360deg); } }

  .nav-actions { display: flex; gap: 0.6rem; }
  .nav-actions .btn {
    flex: 1; padding: 0.8rem; border-radius: 10px; font-weight: 600;
    border: none; cursor: pointer; font-size: 0.95rem;
    display: flex; align-items: center; justify-content: center; gap: 0.4rem;
  }
  .nav-actions .btn-volver { background: #f1f3f4; color: #3c4043; }
  .nav-actions .btn-finalizar { background: #1a73e8; color: #fff; flex: 1.4; }
  .nav-actions .btn-finalizar:active { background: #1765cc; }

  /* ── Pad de firma ── */
  .firma-wrap { position: relative; }
  .firma-canvas {
    width: 100%; height: 180px; border: 2px dashed #cbd5e1;
    border-radius: 10px; background: #fff; display: block; touch-action: none;
  }
  .firma-clear { position: absolute; top: 8px; right: 8px; }
</style>

<div class="nav-wrapper">
  <div class="nav-map-container">
    <div id="map"></div>

    <!-- Header flotante -->
    <div class="nav-top">
      <button class="nav-icon-btn" id="btnBack" title="Volver">←</button>
      <div class="nav-dest-chip">
        <span class="d">📍 <%= op.domicilio || 'Destino a coordinar' %></span>
        <span class="c"><%= op.cliente %><% if (op.tel) { %> · <%= op.tel %><% } %></span>
      </div>
    </div>

    <!-- Botones flotantes -->
    <div class="nav-fabs" id="navFabs">
      <button class="nav-fab" id="fabRoute" title="Ver ruta completa" hidden>🗺️</button>
      <button class="nav-fab" id="fabRecenter" title="Centrar en mi ubicación" hidden>◎</button>
      <button class="nav-fab nav-fab--info" id="fabShowPanel" title="Mostrar info" hidden>ℹ️ Info</button>
    </div>
  </div>

  <!-- Panel inferior -->
  <div class="nav-panel" id="navPanel">
    <div class="nav-grip" id="panelGrip"><span></span></div>

    <div class="nav-stats">
      <div class="nav-stat nav-stat--primary"><b id="distancia">—</b><span>Restante</span></div>
      <div class="nav-stat"><b id="duracion">—</b><span>Tiempo</span></div>
      <div class="nav-stat"><b id="velocidad">0</b><span>km/h</span></div>
      <button class="nav-panel-hide" id="panelHide" title="Esconder panel">✕</button>
    </div>

    <div class="nav-body">
      <div class="nav-dest-card">
        <div class="nav-dest-card__icon">📍</div>
        <div class="nav-dest-card__info">
          <h4><%= op.domicilio || 'Destino a coordinar' %></h4>
          <p><%= op.cliente %><% if (op.tel) { %> · <%= op.tel %><% } %></p>
        </div>
      </div>

      <div class="nav-status" id="statusGPS">
        <span class="spinner"></span>
        <span id="statusText">Inicializando GPS…</span>
      </div>

      <div class="nav-actions">
        <a href="/hoja-de-ruta" class="btn btn-volver">← Volver</a>
        <button type="button" class="btn btn-finalizar" id="btnFinalizar">✓ Finalizar entrega</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal para finalizar viaje -->
<div class="modal fade" id="finalizarModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Confirmar entrega</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/hoja-de-ruta/<%= op.id %>/finalizar" method="POST" enctype="multipart/form-data" id="finalizarForm" data-no-loader>
        <div class="modal-body">
          <label class="form-label fw-semibold mb-1">✍️ Firma del cliente *</label>
          <small class="text-muted d-block mb-1">Pedile al cliente que firme con el dedo en el recuadro</small>
          <div class="firma-wrap">
            <canvas id="firmaCanvas" class="firma-canvas"></canvas>
            <button type="button" class="btn btn-sm btn-outline-secondary firma-clear" id="firmaClear">Limpiar</button>
          </div>
          <input type="hidden" name="firma_cliente" id="firmaInput">

          <label class="form-label fw-semibold mb-1 mt-3">Aclaración (nombre de quien recibe) *</label>
          <input type="text" name="firma_aclaracion" class="form-control form-control-sm" id="firmaNombre"
                 placeholder="Nombre y apellido" required autocomplete="off">

          <label class="form-label fw-semibold mb-1 mt-3">📷 Foto del remito <span class="text-muted fw-normal">(opcional)</span></label>
          <input type="file" name="remito_firmado" accept="image/*,application/pdf" capture="environment"
                 class="form-control form-control-sm remito-input">
          <small class="text-muted d-block">Si querés, adjuntá una foto o PDF del remito en papel</small>

          <div class="remito-preview" style="display:none; margin-top:0.75rem">
            <div class="remito-preview__info text-muted small mb-2">
              <span class="remito-preview__name fw-semibold"></span>
              <span class="remito-preview__size"></span>
            </div>
            <img class="remito-preview__img" alt="Vista previa"
                 style="display:none; max-width:100%; max-height:200px; border-radius:8px; border:1px solid #e0e0e0; margin-bottom:1rem">
            <div class="remito-preview__pdf" style="display:none; padding:0.75rem; background:#f3f4f6; border-radius:8px; text-align:center; margin-bottom:1rem">
              📄 <span class="remito-preview__pdf-name"></span>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary remito-preview__clear">Cambiar</button>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-success">Confirmar entrega</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Leaflet + OpenStreetMap -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-rotate@0.2.8/dist/leaflet-rotate-src.js"></script>
<script src="/js/signaturePad.js"></script>

<script>
(function () {
  'use strict';

  // ── Datos de la operación (inyectados por el backend) ──
  const opId = '<%= op.id %>';
  let destLat = <%= (op.domicilio_lat != null) ? op.domicilio_lat : 'null' %>;
  let destLng = <%= (op.domicilio_lng != null) ? op.domicilio_lng : 'null' %>;
  const domicilio = <%- JSON.stringify(op.domicilio || '') %>;

  // ── Parámetros de navegación ──
  const RECALC_INTERVAL = 12000;  // ms mínimos entre recálculos de ruta
  const DEVIATION_M     = 60;     // desvío (m) que dispara recálculo
  const ARRIVAL_M       = 45;     // distancia (m) para considerar "llegaste"
  const SAVE_INTERVAL   = 8000;   // ms entre envíos de posición al backend

  // ── Estado ──
  let map, userMarker, destMarker, accuracyCircle, routeLine;
  let userLat = null, userLng = null, heading = 0, speedKmh = 0;
  let followMode = true;
  let programmaticMove = false;
  let routeCoords = [];           // [[lat,lng], ...]
  let routeTotalDist = 0, routeTotalDur = 0; // metros, segundos
  let lastNearestIdx = 0;
  let lastRouteCalcAt = 0;
  let firstFitDone = false;
  let watchId = null;
  let arrived = false;
  let lastSaveAt = 0;

  // ── Referencias DOM ──
  const statusEl   = document.getElementById('statusGPS');
  const statusText = document.getElementById('statusText');
  const distanciaEl = document.getElementById('distancia');
  const duracionEl  = document.getElementById('duracion');
  const velocidadEl = document.getElementById('velocidad');
  const fabRecenter = document.getElementById('fabRecenter');
  const fabRoute    = document.getElementById('fabRoute');
  const fabShowPanel = document.getElementById('fabShowPanel');
  const navFabs     = document.getElementById('navFabs');
  const navPanel    = document.getElementById('navPanel');

  // ════════════════════════════════════════════════════════════
  //  Utilidades geográficas
  // ════════════════════════════════════════════════════════════
  function haversine(aLat, aLng, bLat, bLng) {
    const R = 6371000, toRad = Math.PI / 180;
    const dLat = (bLat - aLat) * toRad, dLng = (bLng - aLng) * toRad;
    const la1 = aLat * toRad, la2 = bLat * toRad;
    const h = Math.sin(dLat / 2) ** 2 + Math.cos(la1) * Math.cos(la2) * Math.sin(dLng / 2) ** 2;
    return 2 * R * Math.asin(Math.min(1, Math.sqrt(h)));
  }

  // Índice del vértice de ruta más cercano al punto, buscando hacia adelante
  // desde el último conocido (eficiente en recorridos largos).
  function nearestRouteIndex(lat, lng) {
    if (!routeCoords.length) return { idx: 0, dist: Infinity };
    let best = Infinity, bestIdx = lastNearestIdx;
    const from = Math.max(0, lastNearestIdx - 3);
    const to = routeCoords.length;
    for (let i = from; i < to; i++) {
      const d = haversine(lat, lng, routeCoords[i][0], routeCoords[i][1]);
      if (d < best) { best = d; bestIdx = i; }
      // corte temprano: si ya nos alejamos mucho del mínimo, frenar
      if (d > best + 400) break;
    }
    lastNearestIdx = bestIdx;
    return { idx: bestIdx, dist: best };
  }

  // Distancia restante sumando los segmentos desde el punto más cercano al final
  function remainingDistance(idx, lat, lng) {
    if (!routeCoords.length) return destLat != null ? haversine(lat, lng, destLat, destLng) : 0;
    let d = haversine(lat, lng, routeCoords[idx][0], routeCoords[idx][1]);
    for (let i = idx; i < routeCoords.length - 1; i++) {
      d += haversine(routeCoords[i][0], routeCoords[i][1], routeCoords[i + 1][0], routeCoords[i + 1][1]);
    }
    return d;
  }

  function fmtDist(m) {
    if (m == null || isNaN(m)) return '—';
    return m >= 1000 ? (m / 1000).toFixed(1) + ' km' : Math.round(m) + ' m';
  }
  function fmtMin(sec) {
    if (sec == null || isNaN(sec)) return '—';
    const min = Math.round(sec / 60);
    if (min < 1) return '<1 min';
    if (min < 60) return min + ' min';
    return Math.floor(min / 60) + 'h ' + (min % 60) + 'm';
  }

  // ════════════════════════════════════════════════════════════
  //  Mapa
  // ════════════════════════════════════════════════════════════
  function initMap() {
    map = L.map('map', {
      zoomControl: false,
      attributionControl: false,
      rotate: true, bearing: 0, rotateControl: false,
      // Interacción permitida para explorar; al interactuar se sale del modo seguimiento
      dragging: true, touchZoom: true, scrollWheelZoom: true, doubleClickZoom: true,
    }).setView([destLat != null ? destLat : -31.4203, destLng != null ? destLng : -64.1888], 16);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19, crossOrigin: true,
    }).addTo(map);

    // Marcador del chofer
    userMarker = L.marker([0, 0], {
      zIndexOffset: 1000,
      icon: L.divIcon({
        className: 'nav-puck-icon',
        html: '<div class="nav-puck"><div class="nav-puck__arrow" id="puckArrow"></div><div class="nav-puck__dot"></div></div>',
        iconSize: [34, 34], iconAnchor: [17, 17],
      }),
    });

    // Círculo de precisión
    accuracyCircle = L.circle([0, 0], { radius: 0, color: '#1a73e8', weight: 1, opacity: 0.4, fillColor: '#1a73e8', fillOpacity: 0.08 });

    // Destino
    if (destLat != null && destLng != null) addDestino();

    // Salir del modo seguimiento cuando el usuario arrastra/zoomea manualmente
    map.on('dragstart', onUserInteract);
    map.on('zoomstart', function () { if (!programmaticMove) onUserInteract(); });
    map.on('moveend', function () { programmaticMove = false; });
  }

  function addDestino() {
    if (destMarker || destLat == null) return;
    destMarker = L.marker([destLat, destLng], {
      icon: L.icon({
        iconUrl: 'data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23ea4335"><path d="M12 2c-4.4 0-8 3.6-8 8 0 5.5 8 14 8 14s8-8.5 8-14c0-4.4-3.6-8-8-8zm0 10c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg>',
        iconSize: [36, 36], iconAnchor: [18, 36],
      }),
    }).addTo(map);
  }

  function onUserInteract() {
    if (followMode) {
      followMode = false;
      fabRecenter.hidden = false;
    }
  }

  // ════════════════════════════════════════════════════════════
  //  GPS
  // ════════════════════════════════════════════════════════════
  function startGPS() {
    if (!navigator.geolocation) {
      setStatus('error', 'Este dispositivo no tiene GPS disponible.');
      return;
    }
    setStatus('', 'Obteniendo tu ubicación…');
    navigator.geolocation.getCurrentPosition(onPosition, onPosError,
      { enableHighAccuracy: true, timeout: 12000, maximumAge: 0 });

    if (watchId !== null) navigator.geolocation.clearWatch(watchId);
    watchId = navigator.geolocation.watchPosition(onPosition, onPosError,
      { enableHighAccuracy: true, timeout: 15000, maximumAge: 3000 });
  }

  function onPosition(pos) {
    const c = pos.coords;
    userLat = c.latitude; userLng = c.longitude;
    if (c.speed != null && !isNaN(c.speed)) speedKmh = Math.max(0, c.speed * 3.6);
    if (c.heading != null && !isNaN(c.heading) && c.speed > 0.5) heading = c.heading;

    // Marcador + precisión
    if (!userMarker._map) { userMarker.addTo(map); accuracyCircle.addTo(map); }
    userMarker.setLatLng([userLat, userLng]);
    accuracyCircle.setLatLng([userLat, userLng]).setRadius(c.accuracy || 0);
    updateArrow();

    velocidadEl.textContent = Math.round(speedKmh);
    setStatus('active', 'Navegando hacia el destino');

    saveLocation(c.accuracy);

    // Ruta
    if (destLat != null) {
      const needFirst = !routeCoords.length;
      const dev = needFirst ? false : (nearestRouteIndex(userLat, userLng).dist > DEVIATION_M);
      if (needFirst || dev) calcRoute(needFirst);
      updateProgress();
      detectArrival();
    } else {
      tryGeocodeFallback();
    }

    updateCamera();
  }

  function onPosError(err) {
    let msg = 'No se pudo obtener tu ubicación.';
    let showRetry = true;
    if (err.code === 1) msg = 'Permiso de ubicación denegado. Activalo para navegar.';
    else if (err.code === 2) msg = 'Ubicación no disponible. Revisá el GPS / señal.';
    else if (err.code === 3) msg = 'El GPS tardó demasiado. Reintentando…';
    setStatus('error', msg, showRetry);
  }

  // ════════════════════════════════════════════════════════════
  //  Cámara (seguimiento + rotación)
  // ════════════════════════════════════════════════════════════
  function updateArrow() {
    const arrow = document.getElementById('puckArrow');
    if (!arrow) return;
    // En seguimiento el mapa rota (flecha siempre arriba); si no, la flecha
    // gira para indicar el rumbo real sobre un mapa con el norte arriba.
    arrow.style.transform = 'translateX(-50%) rotate(' + (followMode ? 0 : heading) + 'deg)';
  }

  function updateCamera() {
    if (!followMode || userLat == null) return;
    programmaticMove = true;
    // Zoom inteligente según velocidad
    const z = speedKmh > 60 ? 16 : speedKmh > 25 ? 17 : 18;
    if (typeof map.setBearing === 'function') {
      map.setBearing(heading ? -heading : 0);
    }
    map.setView([userLat, userLng], z, { animate: true, duration: 0.5 });
    updateArrow();
  }

  function recenter() {
    followMode = true;
    fabRecenter.hidden = true;
    updateCamera();
  }

  function showFullRoute() {
    if (!routeLine) return;
    followMode = false;
    fabRecenter.hidden = false;
    programmaticMove = true;
    if (typeof map.setBearing === 'function') map.setBearing(0);
    map.fitBounds(routeLine.getBounds(), { padding: [60, 60] });
  }

  // ════════════════════════════════════════════════════════════
  //  Ruta (OSRM)
  // ════════════════════════════════════════════════════════════
  async function calcRoute(isFirst) {
    if (userLat == null || destLat == null) return;
    const now = Date.now();
    if (!isFirst && now - lastRouteCalcAt < RECALC_INTERVAL) return;
    lastRouteCalcAt = now;

    try {
      const url = 'https://router.project-osrm.org/route/v1/driving/' +
        userLng + ',' + userLat + ';' + destLng + ',' + destLat +
        '?overview=full&geometries=geojson';
      const res = await fetch(url);
      if (!res.ok) throw new Error('OSRM ' + res.status);
      const data = await res.json();
      const route = data.routes && data.routes[0];
      if (!route) throw new Error('sin ruta');

      routeCoords = route.geometry.coordinates.map(function (p) { return [p[1], p[0]]; });
      routeTotalDist = route.distance;
      routeTotalDur = route.duration;
      lastNearestIdx = 0;

      if (routeLine) routeLine.setLatLngs(routeCoords);
      else routeLine = L.polyline(routeCoords, { color: '#1a73e8', weight: 6, opacity: 0.85, lineJoin: 'round', lineCap: 'round' }).addTo(map);

      fabRoute.hidden = false;
      if (isFirst && !firstFitDone) {
        firstFitDone = true;
        // Un vistazo inicial a la ruta completa y luego seguimiento
        programmaticMove = true;
        map.fitBounds(routeLine.getBounds(), { padding: [60, 60] });
        setTimeout(function () { if (followMode) recenter(); }, 1800);
      }
      updateProgress();
    } catch (err) {
      console.error('Error calculando ruta:', err);
      // Sin ruta: igual mostramos distancia en línea recta como referencia
      if (!routeCoords.length && destLat != null && userLat != null) {
        distanciaEl.textContent = fmtDist(haversine(userLat, userLng, destLat, destLng)) + '*';
      }
    }
  }

  function updateProgress() {
    if (destLat == null || userLat == null) return;
    let remaining;
    if (routeCoords.length) {
      const near = nearestRouteIndex(userLat, userLng);
      remaining = remainingDistance(near.idx, userLat, userLng);
    } else {
      remaining = haversine(userLat, userLng, destLat, destLng);
    }
    distanciaEl.textContent = fmtDist(remaining);

    // ETA por velocidad promedio de la ruta (fallback: velocidad actual)
    let etaSec = null;
    if (routeTotalDist > 0 && routeTotalDur > 0) {
      const avg = routeTotalDist / routeTotalDur; // m/s
      if (avg > 0) etaSec = remaining / avg;
    } else if (speedKmh > 3) {
      etaSec = remaining / (speedKmh / 3.6);
    }
    duracionEl.textContent = fmtMin(etaSec);
  }

  function detectArrival() {
    if (arrived || destLat == null || userLat == null) return;
    if (haversine(userLat, userLng, destLat, destLng) <= ARRIVAL_M) {
      arrived = true;
      setStatus('active', '🎉 Llegaste al destino. Confirmá la entrega.');
      if (navigator.vibrate) navigator.vibrate([120, 60, 120]);
    }
  }

  // Fallback de geocodificación en cliente (sólo si el backend no resolvió)
  let geocodeTried = false;
  async function tryGeocodeFallback() {
    if (geocodeTried || destLat != null || !domicilio) return;
    geocodeTried = true;
    try {
      const res = await fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' +
        encodeURIComponent(domicilio + ', Córdoba, Argentina'));
      const data = await res.json();
      if (data && data[0]) {
        destLat = parseFloat(data[0].lat); destLng = parseFloat(data[0].lon);
        addDestino();
        fetch('/hoja-de-ruta/' + opId + '/geocodificar', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lat: destLat, lng: destLng }),
        }).catch(function () {});
        calcRoute(true);
      }
    } catch (err) { console.error('Geocodificación cliente falló:', err); }
  }

  // ════════════════════════════════════════════════════════════
  //  Sincronización con backend
  // ════════════════════════════════════════════════════════════
  function saveLocation(accuracy) {
    const now = Date.now();
    if (now - lastSaveAt < SAVE_INTERVAL) return;
    lastSaveAt = now;
    fetch('/hoja-de-ruta/' + opId + '/ubicacion', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, keepalive: true,
      body: JSON.stringify({ lat: userLat, lng: userLng, accuracy: accuracy || null }),
    }).catch(function () {});
  }

  // ════════════════════════════════════════════════════════════
  //  Estado (UI)
  // ════════════════════════════════════════════════════════════
  function setStatus(kind, text, retry) {
    statusEl.className = 'nav-status' + (kind ? ' ' + kind : '');
    statusText.textContent = text;
    const old = statusEl.querySelector('.nav-status__retry');
    if (old) old.remove();
    if (retry) {
      const b = document.createElement('button');
      b.className = 'nav-status__retry'; b.textContent = 'Reintentar';
      b.addEventListener('click', startGPS);
      statusEl.appendChild(b);
    }
  }

  // ════════════════════════════════════════════════════════════
  //  Panel colapsable / ocultable
  // ════════════════════════════════════════════════════════════
  const PANEL_KEY = 'navPanelState';
  function applyPanelState(state, persist) {
    navPanel.classList.remove('collapsed', 'hidden');
    fabShowPanel.hidden = true;
    if (state === 'collapsed') navPanel.classList.add('collapsed');
    else if (state === 'hidden') { navPanel.classList.add('hidden'); fabShowPanel.hidden = false; }
    if (persist) { try { localStorage.setItem(PANEL_KEY, state); } catch (e) {} }
    // Reajustar el mapa cuando termina la transición de tamaño
    setTimeout(function () {
      if (map) map.invalidateSize({ animate: false });
      if (followMode) updateCamera();
    }, 300);
  }
  function currentPanelState() {
    if (navPanel.classList.contains('hidden')) return 'hidden';
    if (navPanel.classList.contains('collapsed')) return 'collapsed';
    return 'expanded';
  }

  // ════════════════════════════════════════════════════════════
  //  Inicialización
  // ════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function () {
    initMap();

    // Restaurar estado del panel
    let saved = 'expanded';
    try { saved = localStorage.getItem(PANEL_KEY) || 'expanded'; } catch (e) {}
    applyPanelState(saved, false);

    // Controles del panel
    document.getElementById('panelGrip').addEventListener('click', function () {
      applyPanelState(currentPanelState() === 'expanded' ? 'collapsed' : 'expanded', true);
    });
    document.getElementById('panelHide').addEventListener('click', function () {
      applyPanelState('hidden', true);
    });
    fabShowPanel.addEventListener('click', function () { applyPanelState('collapsed', true); });
    fabRecenter.addEventListener('click', recenter);
    fabRoute.addEventListener('click', showFullRoute);
    document.getElementById('btnBack').addEventListener('click', function () { window.location.href = '/hoja-de-ruta'; });

    // Posicionar los FABs por encima del panel
    const ro = function () { navFabs.style.bottom = (navPanel.offsetHeight + 16) + 'px'; };
    ro(); window.addEventListener('resize', ro);
    new MutationObserver(ro).observe(navPanel, { attributes: true, attributeFilter: ['class'] });
    navPanel.addEventListener('transitionend', ro);

    // ── Modal de finalización + firma ──
    const modalEl = document.getElementById('finalizarModal');
    const modal = new bootstrap.Modal(modalEl, { backdrop: 'static' });
    document.getElementById('btnFinalizar').addEventListener('click', function () { modal.show(); });

    const firmaCanvas = document.getElementById('firmaCanvas');
    const firmaInput = document.getElementById('firmaInput');
    const firmaNombre = document.getElementById('firmaNombre');
    const finalizarForm = document.getElementById('finalizarForm');
    const pad = SignaturePad(firmaCanvas);
    modalEl.addEventListener('shown.bs.modal', function () { pad.resize(); });
    document.getElementById('firmaClear').addEventListener('click', function () { pad.clear(); });

    finalizarForm.addEventListener('submit', function (e) {
      if (pad.isEmpty()) { e.preventDefault(); alert('Falta la firma del cliente.'); return; }
      if (!firmaNombre.value.trim()) { e.preventDefault(); alert('Ingresá el nombre de quien recibe.'); firmaNombre.focus(); return; }
      firmaInput.value = pad.toDataURL();
      if (window.AppLoader) window.AppLoader.show('Confirmando entrega…');
    });

    // Preview de la foto del remito
    const remitoInput = document.querySelector('.remito-input');
    const preview = document.querySelector('.remito-preview');
    const img = document.querySelector('.remito-preview__img');
    const pdf = document.querySelector('.remito-preview__pdf');
    const pdfName = document.querySelector('.remito-preview__pdf-name');
    const nameEl = document.querySelector('.remito-preview__name');
    const sizeEl = document.querySelector('.remito-preview__size');
    const clearBtn = document.querySelector('.remito-preview__clear');
    let currentUrl = null;
    function resetPreview() {
      if (currentUrl) { URL.revokeObjectURL(currentUrl); currentUrl = null; }
      preview.style.display = 'none'; img.style.display = 'none'; img.src = '';
      pdf.style.display = 'none'; pdfName.textContent = ''; remitoInput.value = '';
    }
    remitoInput.addEventListener('change', function () {
      if (!remitoInput.files || !remitoInput.files[0]) { resetPreview(); return; }
      const f = remitoInput.files[0];
      const size = f.size > 1048576 ? (f.size / 1048576).toFixed(1) + ' MB' : (f.size / 1024).toFixed(0) + ' KB';
      nameEl.textContent = f.name; sizeEl.textContent = ' · ' + size; preview.style.display = 'block';
      if (currentUrl) URL.revokeObjectURL(currentUrl);
      currentUrl = URL.createObjectURL(f);
      if (f.type.startsWith('image/')) { img.src = currentUrl; img.style.display = 'block'; pdf.style.display = 'none'; }
      else if (f.type === 'application/pdf') { pdfName.textContent = f.name; pdf.style.display = 'block'; img.style.display = 'none'; }
    });
    clearBtn.addEventListener('click', resetPreview);

    // Arrancar GPS
    startGPS();
  });

  // Pausar/reanudar el watch según visibilidad para ahorrar batería
  document.addEventListener('visibilitychange', function () {
    if (document.visibilityState === 'visible' && watchId === null) startGPS();
  });

  window.addEventListener('beforeunload', function () {
    if (watchId !== null) navigator.geolocation.clearWatch(watchId);
  });
})();
</script>
