<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="fw-bold mb-0 text-dark-title">🗺️ Circuito del Día</h4>
    <small class="text-muted">
      Contenedores con plazo vencido — <%= total %> retiro<%= total === 1 ? '' : 's' %> pendiente<%= total === 1 ? '' : 's' %>
    </small>
  </div>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary">🖨️ Imprimir</button>
    <a href="/contenedores" class="btn btn-outline-secondary">← Volver</a>
  </div>
</div>

<% if (!total) { %>
  <div class="card shadow-sm">
    <div class="card-body text-center py-5 text-muted">
      <div class="icon-xl">✅</div>
      <p class="mt-3 mb-0">No hay contenedores con plazo vencido. Todos están al día.</p>
    </div>
  </div>
<% } else { %>

<% Object.keys(porZona).sort().forEach(zona => { %>
  <div class="card shadow-sm mb-3">
    <div class="card-header card-header-orange d-flex justify-content-between align-items-center">
      <span>📍 Zona <%= zona %></span>
      <small class="text-muted"><%= porZona[zona].length %> contenedor<%= porZona[zona].length === 1 ? '' : 'es' %></small>
    </div>
    <div class="card-body p-0">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>N°</th>
            <th>Cliente</th>
            <th>OP</th>
            <th>Domicilio</th>
            <th>WhatsApp</th>
            <th class="text-center">Días en domicilio</th>
            <th class="text-center">Plazo</th>
            <th class="text-center">Exceso</th>
            <th class="text-center">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% porZona[zona].forEach(c => { %>
          <tr>
            <td class="fw-bold text-orange">N° <%= c.numero_contenedor %></td>
            <td class="fw-semibold"><%= c.cliente_nombre %></td>
            <td><small class="text-muted">OP-<%= String(c.nro_op).padStart(4,'0') %></small></td>
            <td><small class="text-muted"><%= c.domicilio_entrega %></small></td>
            <td>
              <% if (c.tel_whatsapp) { %>
                <small><%= c.tel_whatsapp %></small>
              <% } else { %>
                <small class="text-muted">—</small>
              <% } %>
            </td>
            <td class="text-center fw-bold"><%= c.dias_en_domicilio %></td>
            <td class="text-center"><small class="text-muted"><%= c.plazo_alquiler %></small></td>
            <td class="text-center">
              <span class="<%= c.dias_excedidos > 2 ? 'dias-rojo' : 'dias-alerta' %>">
                +<%= c.dias_excedidos %>
              </span>
            </td>
            <td class="text-center">
              <a href="/contenedores/<%= c.id %>" class="btn btn-sm btn-outline-secondary">👁️</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% }) %>

<% } %>

