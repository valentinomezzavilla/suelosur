<%
  const labelEstado = {
    disponible:        'Disponible',
    pendiente_despacho:'Pendiente despacho',
    despachado:        'En camino',
    en_alquiler:       'En alquiler',
    pendiente_retiro:  'Pendiente retiro',
    vuelta_a_planta:   'Vuelta a planta',
  }
  const badgeEstado = {
    disponible:        'badge-activo',
    pendiente_despacho:'badge-pendiente',
    despachado:        'badge-en-transito',
    en_alquiler:       'badge-en-transito',
    pendiente_retiro:  'badge-alerta',
    vuelta_a_planta:   'badge-pendiente',
  }
  const ultimo = contenedor.movimientos[0]
  const libre = !ultimo || ultimo.estado_paso === 'disponible'
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-0 text-dark-title"><%- icon('box', { size: 18 }) %> Contenedor N° <%= contenedor.numero_contenedor %></h4>
    <small class="text-muted">Condición: <%= contenedor.estado_general?.replace('_',' ') %></small>
  </div>
  <div class="d-flex gap-2">
    <a href="/contenedores/<%= contenedor.id %>/editar" class="btn btn-sm btn-outline-secondary"><%- icon('edit', { size: 14 }) %> Editar</a>
    <a href="/contenedores" class="btn btn-sm btn-outline-secondary">← Volver</a>
  </div>
</div>

<div class="row g-4">

  <!-- Estado actual -->
  <div class="col-md-4">
    <div class="card shadow-sm h-100 card-accent-orange">
      <div class="card-body text-center">
        <p class="text-muted small mb-2">Estado actual</p>
        <% if (ultimo) { %>
          <h4>
            <span class="badge rounded-pill px-3 py-2 <%= badgeEstado[ultimo.estado_paso] || 'badge-pendiente' %>">
              <%= labelEstado[ultimo.estado_paso] || ultimo.estado_paso %>
            </span>
          </h4>
          <small class="text-muted">desde el <%= formatFechaHora(ultimo.fecha_movimiento) %></small>
          <%# Si está disponible (libre), no mostramos datos del cliente anterior %>
          <% if (ultimo.cliente_nombre && ultimo.estado_paso !== 'disponible') { %>
            <hr>
            <p class="mb-1 fw-semibold"><%= ultimo.cliente_nombre %></p>
            <small class="text-muted">OP-<%= String(ultimo.nro_op).padStart(4,'0') %></small><br>
            <small class="text-muted">📍 <%= ultimo.domicilio_entrega %></small><br>
            <small class="text-muted">Zona: <%= ultimo.zona_entrega %></small>
          <% } %>
        <% } else { %>
          <p class="text-muted mb-0">Sin movimientos registrados.</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Registrar movimiento -->
  <div class="col-md-8">
    <div class="card shadow-sm h-100">
      <div class="card-header card-header-light">Registrar movimiento</div>
      <div class="card-body">
        <form action="/contenedores/<%= contenedor.id %>/movimiento" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Nuevo estado *</label>
              <select name="estado_paso" class="form-select" required>
                <option value="">Seleccionar...</option>
                <% Object.entries(labelEstado).forEach(([k,v]) => { %>
                  <option value="<%= k %>"><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Fecha y hora</label>
              <input type="datetime-local" name="fecha_movimiento" class="form-control">
              <small class="text-muted">Dejar vacío para usar ahora.</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">Chofer</label>
              <select name="id_chofer" class="form-select">
                <option value="">— sin chofer —</option>
                <% choferes.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Camión</label>
              <select name="id_camion" class="form-select">
                <option value="">— sin camión —</option>
                <% camiones.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %> (<%= c.patente %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">Observaciones</label>
              <input type="text" name="observaciones" class="form-control" placeholder="Notas opcionales...">
            </div>
            <div class="col-12 text-end">
              <button type="submit" class="btn btn-naranja">Registrar movimiento</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Historial -->
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header card-header-light">
        Historial de alquileres (<%= contenedor.alquileres.length %>)
      </div>
      <div class="card-body p-0">
        <% if (!contenedor.alquileres.length) { %>
          <p class="text-muted text-center py-4 mb-0">Este contenedor todavía no tuvo alquileres.</p>
        <% } else { %>
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Inicio</th>
              <th>Fin</th>
              <th>OP / Cliente</th>
              <th>Domicilio</th>
              <th>Zona</th>
              <th class="text-end">Precio</th>
            </tr>
          </thead>
          <tbody>
            <% contenedor.alquileres.forEach((a, idx) => { %>
            <tr>
              <td>
                <% if (a.fecha_inicio) { %>
                  <small class="text-muted"><%= formatFecha(a.fecha_inicio) %></small>
                <% } else if (a.fecha_entrega_planificada) { %>
                  <small class="text-muted"><%= formatFecha(a.fecha_entrega_planificada) %> <span class="badge rounded-pill px-2 badge-pendiente">programado</span></small>
                <% } else { %>
                  <small class="text-muted">—</small>
                <% } %>
              </td>
              <td>
                <% if (a.fecha_fin) { %>
                  <small class="text-muted"><%= formatFecha(a.fecha_fin) %></small>
                <% } else if (!libre && idx === 0) { %>
                  <span class="badge rounded-pill px-2 badge-en-transito">En curso</span>
                <% } else { %>
                  <small class="text-muted">—</small>
                <% } %>
              </td>
              <td>
                <small class="fw-semibold">OP-<%= String(a.nro_op).padStart(4,'0') %></small><br>
                <small class="text-muted"><%= a.cliente_nombre || '—' %></small>
              </td>
              <td><small class="text-muted"><%= a.domicilio_entrega || '—' %></small></td>
              <td><small class="text-muted"><%= a.zona_entrega || '—' %></small></td>
              <td class="text-end"><small class="fw-semibold"><%= a.precio_alquiler ? '$' + Number(a.precio_alquiler).toLocaleString('es-AR') : '—' %></small></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <% if (contenedor.observaciones) { %>
  <div class="col-12">
    <div class="card shadow-sm">
      <div class="card-header card-header-light">Observaciones del contenedor</div>
      <div class="card-body"><%= contenedor.observaciones %></div>
    </div>
  </div>
  <% } %>

</div>
